@using Prompteer.Application.DTOs
@model AISettingsDto
@{
    ViewData["Title"] = L["Settings.Title"].Value;
    var tenantId     = ViewData["AzureAd:TenantId"] as string ?? "";
    var clientId     = ViewData["AzureAd:ClientId"] as string ?? "";
    var domain       = ViewData["AzureAd:Domain"]   as string ?? "";
    var entraEnabled = !string.IsNullOrWhiteSpace(tenantId) && !string.IsNullOrWhiteSpace(clientId);

    // Read from ViewData (set by controller via query-string, no TempData)
    var activeTab      = ViewData["ActiveTab"]      as string ?? "ai";
    var savedScope     = ViewData["SavedScope"]     as string ?? "";
    var errorMsg       = Uri.UnescapeDataString(ViewData["ErrorMsg"] as string ?? "");
    var defaultLang    = ViewData["DefaultLanguage"] as string ?? "en";
    var defaultTz      = ViewData["DefaultTimeZone"] as string ?? "UTC";
    var defaultDateFmt = ViewData["DefaultDateFormat"] as string ?? "MM/dd/yyyy";
    var logoUrl        = ViewData["LogoUrl"] as string ?? "";
}

<div class="max-w-2xl" x-data="{ tab: '@activeTab' }">

    @* Page header *@
    <div class="mb-6">
        <h1 class="text-xl font-semibold text-slate-900">@L["Settings.Title"]</h1>
        <p class="text-sm text-slate-500 mt-0.5">@L["Settings.Subtitle"]</p>
    </div>

    @* Tab bar *@
    <div class="flex gap-1 p-1 bg-slate-100 rounded-xl mb-6 w-fit">
        <button type="button" @@click="tab = 'ai'"
                :class="tab === 'ai'
                    ? 'bg-white text-slate-900 shadow-sm'
                    : 'text-slate-500 hover:text-slate-700'"
                class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all">
            <i data-lucide="cpu" class="w-4 h-4"></i>
            @L["Settings.AIIntegration"]
            @if (Model.IsConfigured)
            {
                <span class="w-2 h-2 rounded-full bg-green-500 ml-0.5"></span>
            }
        </button>
        <button type="button" @@click="tab = 'entra'"
                :class="tab === 'entra'
                    ? 'bg-white text-slate-900 shadow-sm'
                    : 'text-slate-500 hover:text-slate-700'"
                class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all">
            <i data-lucide="shield-check" class="w-4 h-4"></i>
            @L["Settings.MicrosoftEntra"]
            @if (entraEnabled)
            {
                <span class="w-2 h-2 rounded-full bg-green-500 ml-0.5"></span>
            }
        </button>
        <button type="button" @@click="tab = 'general'"
                :class="tab === 'general'
                    ? 'bg-white text-slate-900 shadow-sm'
                    : 'text-slate-500 hover:text-slate-700'"
                class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all">
            <i data-lucide="globe" class="w-4 h-4"></i>
            @L["Settings.General"]
        </button>
    </div>

    @* ── Tab: AI ─────────────────────────────────────────────────────────────── *@
    <div x-show="tab === 'ai'" x-cloak>

        @if (savedScope == "ai")
        {
            <div class="flex items-center gap-2 p-3 mb-5 rounded-xl bg-green-50 border border-green-200 text-green-700 text-sm">
                <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
                <span>@L["Settings.AISaved"]</span>
            </div>
        }

        <form asp-action="Index" method="post" id="settingsForm">
            @Html.AntiForgeryToken()
            <div class="card space-y-6">

                @* Status *@
                <div class="flex items-center gap-2 text-sm">
                    <span class="text-slate-500">@L["Settings.Status"]</span>
                    @if (Model.IsConfigured)
                    {
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>@L["Common.Configured"]
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>@L["Common.NotConfigured"]
                        </span>
                    }
                </div>

                <hr class="border-slate-100" />

                @* Provider *@
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-3">@L["Settings.AIProvider"]</label>
                    <div class="grid grid-cols-2 gap-3">
                        <label class="provider-card cursor-pointer">
                            <input type="radio" asp-for="Provider" value="OpenAI" class="sr-only peer"
                                   onchange="onProviderChange()" />
                            <div class="flex items-center gap-3 p-4 rounded-xl border-2 border-slate-200 peer-checked:border-brand-500 peer-checked:bg-brand-50 transition-all hover:border-slate-300">
                                <div class="w-9 h-9 rounded-lg bg-slate-900 flex items-center justify-center flex-shrink-0">
                                    <span class="text-white text-xs font-bold">AI</span>
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-slate-800">OpenAI</p>
                                    <p class="text-xs text-slate-500">GPT-4o, GPT-4.1…</p>
                                </div>
                            </div>
                        </label>
                        <label class="provider-card cursor-pointer">
                            <input type="radio" asp-for="Provider" value="Anthropic" class="sr-only peer"
                                   onchange="onProviderChange()" />
                            <div class="flex items-center gap-3 p-4 rounded-xl border-2 border-slate-200 peer-checked:border-brand-500 peer-checked:bg-brand-50 transition-all hover:border-slate-300">
                                <div class="w-9 h-9 rounded-lg bg-amber-700 flex items-center justify-center flex-shrink-0">
                                    <i data-lucide="cpu" class="w-4 h-4 text-white"></i>
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-slate-800">Anthropic</p>
                                    <p class="text-xs text-slate-500">Claude 3.5, Claude 3…</p>
                                </div>
                            </div>
                        </label>
                    </div>
                </div>

                @* API Key *@
                <div>
                    <label asp-for="ApiKey" class="block text-sm font-medium text-slate-700 mb-1">
                        @L["Settings.ApiKey"] <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="ApiKey" id="ApiKey" type="password" autocomplete="off"
                           class="form-input w-full font-mono text-sm" placeholder="sk-..." />
                    <p class="text-xs text-slate-400 mt-1">@L["Settings.ApiKeyNote"]</p>
                </div>

                @* Fetch models *@
                <div>
                    <button type="button" id="fetchModelsBtn" onclick="fetchModels()"
                            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium bg-slate-100 text-slate-700 hover:bg-slate-200 border border-slate-200 transition-colors">
                        <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                        @L["Settings.FetchModels"]
                    </button>
                    <p id="fetchError" class="text-xs text-red-600 mt-1 hidden"></p>
                </div>

                @* Model select *@
                <div id="modelSection" class="@(string.IsNullOrEmpty(Model.Model) ? "hidden" : "")">
                    <label asp-for="Model" class="block text-sm font-medium text-slate-700 mb-1">@L["Settings.Model"]</label>
                    <select asp-for="Model" id="Model" class="form-select w-full">
                        @if (!string.IsNullOrEmpty(Model.Model))
                        {
                            <option value="@Model.Model" selected>@Model.Model</option>
                        }
                    </select>
                    <p class="text-xs text-slate-400 mt-1">@L["Settings.ModelNote"]</p>
                </div>

                <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
                    <button type="submit" class="btn btn-primary">
                        <i data-lucide="save" class="w-4 h-4"></i>
                        @L["Settings.SaveAI"]
                    </button>
                </div>
            </div>
        </form>
    </div>

    @* ── Tab: Entra ───────────────────────────────────────────────────────────── *@
    <div x-show="tab === 'entra'" x-cloak>

        @if (savedScope == "entra")
        {
            <div class="flex items-center gap-2 p-3 mb-5 rounded-xl bg-green-50 border border-green-200 text-green-700 text-sm">
                <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
                <span>@L["Settings.EntraSaved"]</span>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMsg) && activeTab == "entra")
        {
            <div class="flex items-start gap-3 p-4 mb-5 rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm">
                <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
                <span>@errorMsg</span>
            </div>
        }

        <form asp-action="SaveEntra" method="post">
            @Html.AntiForgeryToken()
            <div class="card space-y-5">

                @* Status *@
                <div class="flex items-center gap-2 text-sm">
                    <span class="text-slate-500">@L["Settings.Status"]</span>
                    @if (entraEnabled)
                    {
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>@L["Common.Configured"]
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>@L["Common.NotConfigured"]
                        </span>
                    }
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">@L["Settings.TenantId"]</label>
                    <input name="tenantId" value="@tenantId"
                           placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                           class="form-input w-full font-mono text-sm" />
                    <p class="text-xs text-slate-400 mt-1">@L["Settings.TenantIdNote"]</p>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">@L["Settings.ClientId"]</label>
                    <input name="clientId" value="@clientId"
                           placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                           class="form-input w-full font-mono text-sm" />
                    <p class="text-xs text-slate-400 mt-1">@L["Settings.ClientIdNote"]</p>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">
                        @L["Settings.ClientSecret"]
                        @if (entraEnabled)
                        {
                            <span class="text-xs text-slate-400 font-normal ml-1">@L["Settings.ClientSecretKeep"]</span>
                        }
                    </label>
                    <input name="clientSecret" type="password"
                           placeholder="@(entraEnabled ? "••••••••••••" : "")"
                           class="form-input w-full font-mono text-sm" autocomplete="new-password" />
                    <p class="text-xs text-slate-400 mt-1">@L["Settings.ClientSecretNote"]</p>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">
                        @L["Settings.Domain"] <span class="text-slate-400 font-normal text-xs">@L["Settings.DomainOptional"]</span>
                    </label>
                    <input name="domain" value="@domain"
                           placeholder="contoso.onmicrosoft.com"
                           class="form-input w-full text-sm" />
                </div>

                <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
                    <button type="submit" class="btn btn-primary">
                        <i data-lucide="save" class="w-4 h-4"></i>
                        @L["Settings.SaveEntra"]
                    </button>
                    @if (entraEnabled)
                    {
                        <span class="text-xs text-slate-400">@L["Settings.EntraRestartNote"]</span>
                    }
                </div>

                @* Azure setup guide *@
                <div class="flex items-start gap-2.5 p-3.5 rounded-xl bg-blue-50 border border-blue-200">
                    <i data-lucide="info" class="w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5"></i>
                    <div class="text-xs text-blue-700 space-y-1">
                        <p class="font-semibold">@L["Settings.AzureGuideTitle"]</p>
                        <ol class="list-decimal list-inside space-y-0.5">
                            <li>Azure Portal → Microsoft Entra ID → App registrations → New registration</li>
                            <li>Redirect URI: <code class="bg-blue-100 px-1 rounded">https://yourdomain/signin-oidc</code></li>
                            <li>API permissions: <code class="bg-blue-100 px-1 rounded">User.Read</code>, <code class="bg-blue-100 px-1 rounded">User.ReadBasic.All</code></li>
                            <li>App roles: create <code class="bg-blue-100 px-1 rounded">Admin</code>, <code class="bg-blue-100 px-1 rounded">Editor</code>, <code class="bg-blue-100 px-1 rounded">Viewer</code></li>
                            <li>Assign users in Enterprise applications → Users and groups</li>
                        </ol>
                    </div>
                </div>
            </div>
        </form>
    </div>

    @* ── Tab: General ─────────────────────────────────────────────────────────── *@
    <div x-show="tab === 'general'" x-cloak>

        @if (savedScope == "general")
        {
            <div class="flex items-center gap-2 p-3 mb-5 rounded-xl bg-green-50 border border-green-200 text-green-700 text-sm">
                <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
                <span>@L["Settings.GeneralSaved"]</span>
            </div>
        }

        <form asp-action="SaveGeneral" method="post">
            @Html.AntiForgeryToken()
            <div class="card space-y-5">

                <div class="text-sm text-slate-500">@L["Settings.GeneralSubtitle"]</div>

                <hr class="border-slate-100" />

                @* Default Language *@
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">@L["Settings.DefaultLanguage"]</label>
                    <select name="language" class="form-select w-full">
                        @if (defaultLang == "en")
                        {
                            <option value="en" selected>@L["Lang.English"] (en)</option>
                            <option value="pt-BR">@L["Lang.Portuguese"] (pt-BR)</option>
                        }
                        else
                        {
                            <option value="en">@L["Lang.English"] (en)</option>
                            <option value="pt-BR" selected>@L["Lang.Portuguese"] (pt-BR)</option>
                        }
                    </select>
                    <p class="text-xs text-slate-400 mt-1">@L["Settings.DefaultLanguageNote"]</p>
                </div>

                @* Time Zone *@
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">@L["Settings.TimeZone"]</label>
                    <select name="timeZone" class="form-select w-full">
                        @foreach (var tz in TimeZoneInfo.GetSystemTimeZones())
                        {
                            if (defaultTz == tz.Id)
                            {
                                <option value="@tz.Id" selected>@tz.DisplayName</option>
                            }
                            else
                            {
                                <option value="@tz.Id">@tz.DisplayName</option>
                            }
                        }
                    </select>
                    <p class="text-xs text-slate-400 mt-1">@L["Settings.TimeZoneNote"]</p>
                </div>

                @* Date Format *@
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">@L["Settings.DateFormat"]</label>
                    <select name="dateFormat" class="form-select w-full">
                        @foreach (var (val, label) in new[]
                        {
                            ("MM/dd/yyyy",  "MM/dd/yyyy (12/31/2024)"),
                            ("dd/MM/yyyy",  "dd/MM/yyyy (31/12/2024)"),
                            ("yyyy-MM-dd",  "yyyy-MM-dd (2024-12-31)"),
                            ("dd MMM yyyy", "dd MMM yyyy (31 Dec 2024)"),
                        })
                        {
                            if (defaultDateFmt == val)
                            {
                                <option value="@val" selected>@label</option>
                            }
                            else
                            {
                                <option value="@val">@label</option>
                            }
                        }
                    </select>
                    <p class="text-xs text-slate-400 mt-1">@L["Settings.DateFormatNote"]</p>
                </div>

                @* Logo URL *@
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">@L["Settings.LogoUrl"]</label>
                    <input name="logoUrl" value="@logoUrl" type="url"
                           placeholder="https://example.com/logo.png"
                           class="form-input w-full text-sm" />
                    <p class="text-xs text-slate-400 mt-1">@L["Settings.LogoUrlNote"]</p>
                    @if (!string.IsNullOrWhiteSpace(logoUrl))
                    {
                        <div class="mt-2 flex items-center gap-3">
                            <img src="@logoUrl" alt="Logo preview" class="h-10 max-w-[160px] object-contain rounded border border-slate-200 p-1 bg-white" />
                            <span class="text-xs text-slate-400">@L["Common.Preview"]</span>
                        </div>
                    }
                </div>

                <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
                    <button type="submit" class="btn btn-primary">
                        <i data-lucide="save" class="w-4 h-4"></i>
                        @L["Settings.SaveGeneral"]
                    </button>
                </div>
            </div>
        </form>
    </div>

</div>

@section Scripts {
<script>
const _errSelectProvider = '@L["Settings.SelectProvider"].Value.Replace("'", "\\'")';
const _errFetchModels    = '@L["Settings.ErrorFetchModels"].Value.Replace("'", "\\'")';
const _errServerComm     = '@L["Settings.ErrorServerComm"].Value.Replace("'", "\\'")';
const _fetchingLabel     = '@L["Settings.FetchingModels"].Value.Replace("'", "\\'")';
const _fetchLabel        = '@L["Settings.FetchModels"].Value.Replace("'", "\\'")';

function onProviderChange() {
    document.getElementById('Model').innerHTML = '';
    document.getElementById('modelSection').classList.add('hidden');
    document.getElementById('fetchError').classList.add('hidden');
}

async function fetchModels() {
    const provider = document.querySelector('input[name="Provider"]:checked')?.value;
    const apiKey   = document.getElementById('ApiKey').value.trim();
    const btn      = document.getElementById('fetchModelsBtn');
    const errEl    = document.getElementById('fetchError');

    if (!provider) { errEl.textContent = _errSelectProvider; errEl.classList.remove('hidden'); return; }

    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin w-4 h-4 inline mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>' + _fetchingLabel;
    errEl.classList.add('hidden');

    try {
        const params = new URLSearchParams({ provider });
        if (apiKey) params.append('apiKey', apiKey);
        const resp = await fetch('/Settings/GetModels?' + params.toString());
        const data = await resp.json();

        if (data.success) {
            const select       = document.getElementById('Model');
            const currentModel = select.value;
            select.innerHTML   = '';
            data.models.forEach(m => {
                const opt       = document.createElement('option');
                opt.value       = m.id;
                opt.textContent = m.displayName || m.id;
                if (m.id === currentModel) opt.selected = true;
                select.appendChild(opt);
            });
            document.getElementById('modelSection').classList.remove('hidden');
        } else {
            errEl.textContent = data.error ?? _errFetchModels;
            errEl.classList.remove('hidden');
        }
    } catch {
        errEl.textContent = _errServerComm;
        errEl.classList.remove('hidden');
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="refresh-cw" class="w-4 h-4 inline mr-1"></i>' + _fetchLabel;
        lucide.createIcons();
    }
}
</script>
}
