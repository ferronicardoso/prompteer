@using Prompteer.Domain.Enums
@using Prompteer.Domain.Entities
@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Users";
    var search   = ViewBag.Search as string ?? string.Empty;
    var page     = (int)ViewBag.Page;
    var pageSize = (int)ViewBag.PageSize;
    var total    = (int)ViewBag.Total;
    var pages    = (int)Math.Ceiling(total / (double)pageSize);

    string RoleBadge(UserRole role) => role switch
    {
        UserRole.Admin  => "bg-red-100 text-red-700",
        UserRole.Editor => "bg-blue-100 text-blue-700",
        _               => "bg-gray-100 text-gray-600"
    };
}

<div class="space-y-6">
    @* Header *@
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">@L["Users.Title"]</h1>
            <p class="text-sm text-gray-500 mt-0.5">@L["Users.Subtitle"]</p>
        </div>
        <a href="https://entra.microsoft.com/#view/Microsoft_AAD_IAM/UsersManagementMenuBlade/~/AllUsers"
           target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-indigo-600 bg-indigo-50 border border-indigo-200 rounded-lg hover:bg-indigo-100 transition-colors">
            <i data-lucide="external-link" class="w-4 h-4"></i>
            @L["Users.ManageInEntra"]
        </a>
    </div>

    @* Info banner *@
    <div class="flex items-start gap-3 p-4 rounded-xl bg-blue-50 border border-blue-200 text-blue-800 text-sm">
        <i data-lucide="info" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
        <div>
            <p class="font-semibold">@L["Users.RolesManagedInEntra"]</p>
            <p class="mt-0.5 text-blue-700">@L["Users.RolesNote"]</p>
        </div>
    </div>

    @* Alert *@
    @if (TempData["Success"] is string msg)
    {
        <div class="flex items-center gap-3 p-4 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm">
            <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0"></i>
            @msg
        </div>
    }

    @* Search *@
    <form method="get" class="flex gap-3 max-w-md">
        <input type="text" name="search" value="@search" placeholder="@L["Users.SearchPlaceholder"]"
               class="flex-1 px-4 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        <button type="submit"
                class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors">
            @L["Users.Search"]
        </button>
    </form>

    @* Table *@
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        @if (!Model.Any())
        {
            <div class="flex flex-col items-center justify-center py-16 text-center text-gray-400">
                <i data-lucide="users" class="w-12 h-12 mb-3 opacity-30"></i>
                <p class="font-medium">@L["Users.NoResults"]</p>
                @if (!string.IsNullOrWhiteSpace(search))
                {
                    <p class="text-sm mt-1">@L["Users.NoResultsHint"]</p>
                }
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-100 bg-gray-50">
                        <th class="px-5 py-3 text-left font-semibold text-gray-600">@L["Users.UserHeader"]</th>
                        <th class="px-5 py-3 text-left font-semibold text-gray-600">@L["Users.Email"]</th>
                        <th class="px-5 py-3 text-left font-semibold text-gray-600">@L["Common.Role"]</th>
                        <th class="px-5 py-3 text-left font-semibold text-gray-600">@L["Common.Status"]</th>
                        <th class="px-5 py-3 text-left font-semibold text-gray-600">@L["Common.LastAccess"]</th>
                        <th class="px-5 py-3 text-right font-semibold text-gray-600">@L["Common.Actions"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var user in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-5 py-3.5">
                                <div class="flex items-center gap-3">
                                    <div class="relative w-9 h-9 flex-shrink-0">
                                        <img src="/Account/Photo?oid=@user.EntraObjectId"
                                             alt="@user.DisplayName"
                                             class="w-9 h-9 rounded-full object-cover"
                                             onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                                             loading="lazy" />
                                        <div class="w-9 h-9 rounded-full bg-indigo-100 items-center justify-center text-indigo-700 font-bold text-sm uppercase absolute inset-0"
                                             style="display:none;">
                                            @(user.DisplayName.Length > 0 ? user.DisplayName[0].ToString() : "?")
                                        </div>
                                    </div>
                                    <span class="font-medium text-gray-900">@user.DisplayName</span>
                                </div>
                            </td>
                            <td class="px-5 py-3.5 text-gray-600">@user.Email</td>
                            <td class="px-5 py-3.5">
                                <span class="px-2 py-0.5 rounded-full text-xs font-semibold @RoleBadge(user.Role)">
                                    @user.Role
                                </span>
                            </td>
                            <td class="px-5 py-3.5">
                                @if (user.IsActive)
                                {
                                    <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">@L["Users.Active"]</span>
                                }
                                else
                                {
                                    <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500">@L["Users.Inactive"]</span>
                                }
                            </td>
                            <td class="px-5 py-3.5 text-gray-500">
                                @(user.LastLoginAt?.ToString((string)ViewData["DateTimeFormat"]!) ?? L["Common.Never"].Value)
                            </td>
                            <td class="px-5 py-3.5">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@user.Id"
                                       class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-indigo-600 bg-indigo-50 rounded-lg hover:bg-indigo-100 transition-colors">
                                        <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                        @L["Common.Edit"]
                                    </a>
                                    @if (user.IsActive)
                                    {
                                        <form asp-action="Deactivate" asp-route-id="@user.Id" method="post"
                                              onsubmit="return confirm('@string.Format(L["Users.DeactivateConfirm"].Value, Html.Raw(user.DisplayName.Replace("'", "\\'"))))')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100 transition-colors">
                                                <i data-lucide="user-x" class="w-3.5 h-3.5"></i>
                                                @L["Users.Deactivate"]
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* Pagination *@
    @if (pages > 1)
    {
        <div class="flex items-center justify-between text-sm text-gray-600">
            <span>@total @L["Users.Found"]</span>
            <div class="flex gap-1">
                @for (var p = 1; p <= pages; p++)
                {
                    <a asp-action="Index" asp-route-page="@p" asp-route-search="@search"
                       class="px-3 py-1.5 rounded-lg border @(p == page ? "border-indigo-500 bg-indigo-50 text-indigo-700 font-semibold" : "border-gray-200 hover:bg-gray-50")">
                        @p
                    </a>
                }
            </div>
        </div>
    }
</div>
