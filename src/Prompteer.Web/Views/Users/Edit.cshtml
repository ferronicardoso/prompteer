@using Prompteer.Domain.Enums
@using Prompteer.Domain.Entities
@model ApplicationUser

@{
    ViewData["Title"] = "Edit User";

    string RoleBadge(UserRole role) => role switch
    {
        UserRole.Admin  => "bg-red-100 text-red-700",
        UserRole.Editor => "bg-blue-100 text-blue-700",
        _               => "bg-gray-100 text-gray-600"
    };
}

<div class="max-w-lg mx-auto space-y-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">@L["Users.Edit.Title"]</h1>
        <p class="text-sm text-gray-500 mt-0.5">@L["Users.Edit.Subtitle"]</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">

        @* User info (read-only) *@
        <div class="flex items-center gap-4 pb-5 border-b border-gray-100">
            <div class="relative w-14 h-14 flex-shrink-0">
                <img src="/Account/Photo?oid=@Model.EntraObjectId"
                     alt="@Model.DisplayName"
                     class="w-14 h-14 rounded-full object-cover"
                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                     loading="lazy" />
                <div class="w-14 h-14 rounded-full bg-indigo-100 items-center justify-center text-indigo-700 font-bold text-xl uppercase absolute inset-0"
                     style="display:none;">
                    @(Model.DisplayName.Length > 0 ? Model.DisplayName[0].ToString() : "?")
                </div>
            </div>
            <div>
                <p class="font-semibold text-gray-900">@Model.DisplayName</p>
                <p class="text-sm text-gray-500">@Model.Email</p>
                <p class="text-xs text-gray-400 mt-0.5 font-mono">@Model.EntraObjectId</p>
            </div>
        </div>

        @* Role — read-only, managed in Entra *@
        <div class="p-4 rounded-xl bg-amber-50 border border-amber-200">
            <div class="flex items-start gap-3">
                <i data-lucide="shield" class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5"></i>
                <div>
                    <p class="text-sm font-semibold text-amber-800">@L["Users.Edit.CurrentRole"]</p>
                    <div class="flex items-center gap-2 mt-1.5">
                        <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold @RoleBadge(Model.Role)">
                            @Model.Role
                        </span>
                        <span class="text-xs text-amber-700">
                            @L["Users.Edit.SyncedLastLogin"]
                        </span>
                    </div>
                    <p class="text-xs text-amber-600 mt-2">
                        @L["Users.Edit.RoleNote"]
                    </p>
                </div>
            </div>
        </div>

        @* Active toggle — único campo editável aqui *@
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="space-y-5">
            @Html.AntiForgeryToken()

            <div class="flex items-center justify-between py-3 border-y border-gray-100">
                <div>
                    <p class="text-sm font-medium text-gray-700">@L["Users.Edit.ActiveAccess"]</p>
                    <p class="text-xs text-gray-400 mt-0.5">@L["Users.Edit.ActiveNote"]</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="hidden" name="isActive" value="false" />
                    <input type="checkbox" name="isActive" value="true" @(Model.IsActive ? "checked" : "")
                           class="sr-only peer" />
                    <div class="w-11 h-6 bg-gray-200 rounded-full peer peer-focus:ring-2 peer-focus:ring-indigo-300
                                peer-checked:bg-indigo-600
                                after:content-[''] after:absolute after:top-0.5 after:left-0.5
                                after:bg-white after:rounded-full after:h-5 after:w-5
                                after:transition-all peer-checked:after:translate-x-5">
                    </div>
                </label>
            </div>

            <div class="flex items-center gap-3">
                <button type="submit"
                        class="px-5 py-2.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-colors">
                    @L["Common.Save"]
                </button>
                <a asp-action="Index"
                   class="px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
                    @L["Common.Cancel"]
                </a>
            </div>
        </form>
    </div>

    @* Last login info *@
    @if (Model.LastLoginAt.HasValue)
    {
        <p class="text-xs text-gray-400 text-center">
            @L["Users.Edit.LastAccess"] @Model.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm") UTC
        </p>
    }
</div>
