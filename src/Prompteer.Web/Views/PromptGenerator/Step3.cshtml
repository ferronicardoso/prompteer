@using Prompteer.Web.Models
@using Prompteer.Application.DTOs
@model WizardViewModel
@{
    ViewData["Title"] = "Gerador de Prompts — Passo 3: Projeto";
    var techGroups = Model.Technologies.GroupBy(t => t.CategoryDisplay).OrderBy(g => g.Key);
    var selectedTechIds = Model.Data.TechnologyIds.Select(id => id.ToString()).ToHashSet();
}

<div class="max-w-3xl">
    <partial name="_StepLayout" model="Model" />

    <div class="mb-6">
        <h1 class="text-xl font-semibold text-slate-900">Passo 3 — Projeto</h1>
        <p class="text-sm text-slate-500 mt-1">Defina o nome, descrição e as tecnologias do projeto.</p>
    </div>

    <form method="post" asp-action="Step" asp-route-step="3" asp-route-draftId="@Model.DraftId">
        @Html.AntiForgeryToken()

        <div class="card space-y-6">
            <!-- Project Name -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Nome do Projeto <span class="text-red-500">*</span></label>
                <input type="text" name="ProjectName" value="@Model.Data.ProjectName" class="form-input w-full"
                       placeholder="Ex: Sistema de Gestão de Pedidos" />
            </div>

            <!-- Project Description -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Descrição do Projeto</label>
                <textarea name="ProjectDescription" rows="4" class="form-textarea w-full"
                          placeholder="Descreva o objetivo e contexto do projeto...">@Model.Data.ProjectDescription</textarea>
            </div>

            <!-- Technologies -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Tecnologias</label>
                <select id="techSelect" name="TechnologyIds" multiple class="form-select w-full">
                    @foreach (var group in techGroups)
                    {
                        <optgroup label="@group.Key">
                            @foreach (var tech in group)
                            {
                                var label = tech.Version is null ? tech.Name : $"{tech.Name} {tech.Version}";
                                <option value="@tech.Id" selected="@(selectedTechIds.Contains(tech.Id.ToString()) ? "selected" : null)">@label</option>
                            }
                        </optgroup>
                    }
                </select>
            </div>

            <!-- Inline Create Technology -->
            <div x-data="{ open: false }" class="border border-slate-200 rounded-lg">
                <button type="button" @@click="open = !open"
                        class="w-full flex items-center gap-2 px-4 py-3 text-sm text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg transition-colors">
                    <i data-lucide="plus-circle" class="w-4 h-4 text-brand-600"></i>
                    <span>Adicionar nova tecnologia</span>
                    <i data-lucide="chevron-down" class="w-3.5 h-3.5 ml-auto transition-transform" :class="open && 'rotate-180'"></i>
                </button>
                <div x-show="open" x-collapse class="border-t border-slate-200 p-4 space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-slate-700 mb-1">Nome <span class="text-red-500">*</span></label>
                            <input id="newTechName" type="text" class="form-input w-full" placeholder="Ex: .NET, React, PostgreSQL" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-700 mb-1">Versão</label>
                            <input id="newTechVersion" type="text" class="form-input w-full" placeholder="Ex: 8.0, 18, 16" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-700 mb-1">Categoria <span class="text-red-500">*</span></label>
                            <select id="newTechCategory" class="form-select w-full">
                                <option value="0">Framework</option>
                                <option value="1">Banco de Dados</option>
                                <option value="2">ORM</option>
                                <option value="3">Frontend</option>
                                <option value="4">Autenticação</option>
                                <option value="5">Mensageria</option>
                                <option value="6">Cache</option>
                                <option value="7">Observabilidade</option>
                                <option value="8">DevOps</option>
                                <option value="9">Testes</option>
                                <option value="10">Outro</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-700 mb-1">Ecossistema <span class="text-red-500">*</span></label>
                            <select id="newTechEcosystem" class="form-select w-full">
                                <option value="0">.NET</option>
                                <option value="1">Node.js</option>
                                <option value="2">Python</option>
                                <option value="3">Java</option>
                                <option value="4">Agnóstico</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-700 mb-1">Descrição Curta</label>
                        <input id="newTechDesc" type="text" class="form-input w-full" placeholder="Breve descrição da tecnologia..." />
                    </div>
                    <div id="newTechError" class="hidden text-xs text-red-600"></div>
                    <button type="button" id="btnCreateTech" class="btn btn-primary text-sm">
                        <i data-lucide="save" class="w-3.5 h-3.5"></i>
                        Adicionar Tecnologia
                    </button>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-between mt-6">
            <button type="submit" formaction="@Url.Action("Previous", new { step = 3, draftId = Model.DraftId })" class="btn btn-secondary">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                Voltar
            </button>
            <button type="submit" class="btn btn-primary">
                Próximo
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
(function () {
    const ts = new TomSelect('#techSelect', {
        plugins: ['remove_button'],
        placeholder: 'Selecione tecnologias...',
        closeAfterSelect: false
    });

    document.getElementById('btnCreateTech').addEventListener('click', async function () {
        const name = document.getElementById('newTechName').value.trim();
        const version = document.getElementById('newTechVersion').value.trim() || null;
        const category = parseInt(document.getElementById('newTechCategory').value);
        const ecosystem = parseInt(document.getElementById('newTechEcosystem').value);
        const desc = document.getElementById('newTechDesc').value.trim() || null;
        const errEl = document.getElementById('newTechError');

        if (!name) {
            errEl.textContent = 'Informe o nome da tecnologia.';
            errEl.classList.remove('hidden');
            return;
        }
        errEl.classList.add('hidden');

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const fd = new FormData();
        fd.append('__RequestVerificationToken', token);
        fd.append('Name', name);
        if (version) fd.append('Version', version);
        fd.append('Category', category);
        fd.append('Ecosystem', ecosystem);
        if (desc) fd.append('ShortDescription', desc);

        try {
            const resp = await fetch('@Url.Action("CreateTechnology")', { method: 'POST', body: fd });
            const data = await resp.json();
            ts.addOption({ value: data.id, text: data.label });
            ts.addItem(data.id);
            document.getElementById('newTechName').value = '';
            document.getElementById('newTechVersion').value = '';
            document.getElementById('newTechDesc').value = '';
        } catch {
            errEl.textContent = 'Erro ao adicionar tecnologia. Tente novamente.';
            errEl.classList.remove('hidden');
        }
    });
})();
</script>
}
