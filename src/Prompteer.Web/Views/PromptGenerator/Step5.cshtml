@using Prompteer.Web.Models
@model WizardViewModel
@{
    ViewData["Title"] = "Prompt Generator — Step 5: Environment";
    var targets = Model.Data.DeploymentTargets;
    var allTargets = new[] { "Docker", "Docker Swarm", "Kubernetes", "AWS", "Azure", "GCP", "OCI", "Bare Metal" };
    var gitStrategy = Model.Data.GitStrategy ?? "";
    var cicdTools = new[] { "Azure DevOps", "GitHub Actions", "GitLab CI", "Jenkins", "CircleCI" };
}

<div class="max-w-3xl">
    <partial name="_StepLayout" model="Model" />

    <div class="mb-6">
        <h1 class="text-xl font-semibold text-slate-900">@L["PromptGenerator.Step5.Title"]</h1>
        <p class="text-sm text-slate-500 mt-1">@L["PromptGenerator.Step5.Subtitle"]</p>
    </div>

    <form method="post" asp-action="Step" asp-route-step="5" asp-route-draftId="@Model.DraftId"
          x-data="{
            active: @(Model.Data.IncludeEnvironment ? "true" : "false"),
            cicd: @(Model.Data.IncludeCICD ? "true" : "false")
          }">
        @Html.AntiForgeryToken()
        <input type="hidden" name="IncludeEnvironment" :value="active ? 'true' : 'false'" />
        <input type="hidden" name="IncludeCICD" :value="cicd ? 'true' : 'false'" />

        <div class="card space-y-6">
            <!-- Toggle -->
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-slate-700">@L["PromptGenerator.Step5.IncludeToggle"]</p>
                    <p class="text-xs text-slate-500">@L["PromptGenerator.Step5.DisableNote"]</p>
                </div>
                <button type="button" @@click="active = !active"
                        class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none"
                        :class="active ? 'bg-brand-600' : 'bg-slate-300'">
                    <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform shadow"
                          :class="active ? 'translate-x-6' : 'translate-x-1'"></span>
                </button>
            </div>

            <div x-show="active" x-transition>
                <!-- Deployment Targets -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-slate-700 mb-3">@L["PromptGenerator.Step5.DeploymentTargets"]</label>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                        @foreach (var t in allTargets)
                        {
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" name="DeploymentTargets" value="@t"
                                       @(targets.Contains(t) ? "checked" : "")
                                       class="w-4 h-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" />
                                <span class="text-sm text-slate-700">@t</span>
                            </label>
                        }
                    </div>
                </div>

                <!-- Git Strategy -->
                <div class="mb-6">
                    <label class="block text-sm font-medium text-slate-700 mb-3">@L["PromptGenerator.Step5.BranchStrategy"]</label>
                    <div class="flex flex-wrap gap-4">
                        @foreach (var strategy in new[] { "GitFlow", "Trunk-based", "Feature Branches" })
                        {
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="GitStrategy" value="@strategy"
                                       @(gitStrategy == strategy ? "checked" : "")
                                       class="w-4 h-4 border-slate-300 text-brand-600 focus:ring-brand-500" />
                                <span class="text-sm text-slate-700">@strategy</span>
                            </label>
                        }
                    </div>
                </div>

                <!-- CI/CD -->
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <label class="block text-sm font-medium text-slate-700">@L["PromptGenerator.Step5.IncludeCICD"]</label>
                        <button type="button" @@click="cicd = !cicd"
                                class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none"
                                :class="cicd ? 'bg-brand-600' : 'bg-slate-300'">
                            <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform shadow"
                                  :class="cicd ? 'translate-x-6' : 'translate-x-1'"></span>
                        </button>
                    </div>

                    <div x-show="cicd" x-transition>
                        <label class="block text-xs font-medium text-slate-700 mb-1">@L["PromptGenerator.Step5.CICDTool"]</label>
                        <select name="CICDTool" class="form-select w-full">
                            <option value="">@L["PromptGenerator.Step5.SelectCICD"]</option>
                            @foreach (var tool in cicdTools)
                            {
                                <option value="@tool" selected="@(Model.Data.CICDTool == tool ? "selected" : null)">@tool</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-between mt-6">
            <button type="submit" formaction="@Url.Action("Previous", new { step = 5, draftId = Model.DraftId })" class="btn btn-secondary">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                @L["PromptGenerator.Back"]
            </button>
            <div class="flex gap-3">
                <button type="submit" x-show="!active"
                        class="btn btn-ghost text-slate-500 hover:text-slate-700">
                    @L["PromptGenerator.SkipStep"]
                    <i data-lucide="skip-forward" class="w-4 h-4"></i>
                </button>
                <button type="submit" class="btn btn-primary">
                    @L["PromptGenerator.Next"]
                    <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </button>
            </div>
        </div>
    </form>
</div>
