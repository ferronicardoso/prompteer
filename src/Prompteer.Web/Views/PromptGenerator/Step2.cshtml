@using Prompteer.Web.Models
@model WizardViewModel
@{
    ViewData["Title"] = "Prompt Generator — Step 2: Backlog";
    var selectedToolId = Model.Data.BacklogToolId?.ToString() ?? "";
}

<div class="max-w-3xl">
    <partial name="_StepLayout" model="Model" />

    <div class="mb-6">
        <h1 class="text-xl font-semibold text-slate-900">@L["PromptGenerator.Step2.Title"]</h1>
        <p class="text-sm text-slate-500 mt-1">@L["PromptGenerator.Step2.Subtitle"]</p>
    </div>

    <form method="post" asp-action="Step" asp-route-step="2" asp-route-draftId="@Model.DraftId">
        @Html.AntiForgeryToken()

        <div class="card space-y-6">
            <!-- Backlog Tool Select -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">@L["PromptGenerator.Step2.BacklogTool"]</label>
                <select id="backlogToolSelect" name="BacklogToolId" class="form-select w-full">
                    <option value="">@L["PromptGenerator.Step2.NoTool"]</option>
                    @foreach (var tool in Model.BacklogTools)
                    {
                        <option value="@tool.Id"
                                data-instructions="@tool.DefaultInstructions"
                                selected="@(tool.Id.ToString() == selectedToolId ? "selected" : null)">
                            @tool.Name
                        </option>
                    }
                </select>
            </div>

            <!-- Instructions -->
            <div>
                <div class="flex items-center justify-between mb-1">
                    <label class="block text-sm font-medium text-slate-700">@L["PromptGenerator.Step2.BacklogInstructions"]</label>
                    <div class="flex items-center gap-1 text-xs">
                        <button type="button" id="btnTabEdit"
                                class="px-2.5 py-1 rounded font-medium text-slate-500 hover:text-slate-700 transition-colors">
                            @L["PromptGenerator.Step2.Edit"]
                        </button>
                        <button type="button" id="btnTabPreview"
                                class="px-2.5 py-1 rounded font-medium bg-brand-600 text-white transition-colors">
                            @L["PromptGenerator.Step2.Preview"]
                        </button>
                    </div>
                </div>
                <div id="editPane" class="hidden">
                    <textarea id="backlogInstructions" name="BacklogInstructions" rows="8"
                              class="form-textarea w-full"
                              placeholder="Describe how the backlog should be managed...">@Model.Data.BacklogInstructions</textarea>
                </div>
                <div id="previewPane" class="overflow-auto max-h-64 rounded-lg border border-slate-200 bg-white p-4">
                    <div id="instructionsRendered" class="markdown-body"></div>
                </div>
                <p class="text-xs text-slate-400 mt-1">@L["PromptGenerator.Step2.AutoFillNote"]</p>
            </div>

            <!-- Inline Create Backlog Tool -->
            <div x-data="{ open: false }" class="border border-slate-200 rounded-lg">
                <button type="button" @@click="open = !open"
                        class="w-full flex items-center gap-2 px-4 py-3 text-sm text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg transition-colors">
                    <i data-lucide="plus-circle" class="w-4 h-4 text-brand-600"></i>
                    <span>@L["PromptGenerator.Step2.CreateNew"]</span>
                    <i data-lucide="chevron-down" class="w-3.5 h-3.5 ml-auto transition-transform" :class="open && 'rotate-180'"></i>
                </button>
                <div x-show="open" x-collapse class="border-t border-slate-200 p-4 space-y-4">
                    <div>
                        <label class="block text-xs font-medium text-slate-700 mb-1">@L["Common.Name"] <span class="text-red-500">*</span></label>
                        <input id="newToolName" type="text" class="form-input w-full" placeholder="Ex: Jira, Linear, Azure DevOps" />
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-700 mb-1">@L["BacklogTools.DefaultInstructions"]</label>
                        <textarea id="newToolInstructions" rows="3" class="form-textarea w-full"
                                  placeholder="Default instructions for this tool..."></textarea>
                    </div>
                    <div id="newToolError" class="hidden text-xs text-red-600"></div>
                    <button type="button" id="btnCreateTool" class="btn btn-primary text-sm">
                        <i data-lucide="save" class="w-3.5 h-3.5"></i>
                        @L["PromptGenerator.Step2.CreateTool"]
                    </button>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-between mt-6">
            <button type="submit" formaction="@Url.Action("Previous", new { step = 2, draftId = Model.DraftId })" class="btn btn-secondary">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                @L["PromptGenerator.Back"]
            </button>
            <button type="submit" class="btn btn-primary">
                @L["PromptGenerator.Next"]
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
(function () {
    // ── Preview tabs ──────────────────────────────────────────────
    const textarea    = document.getElementById('backlogInstructions');
    const editPane    = document.getElementById('editPane');
    const previewPane = document.getElementById('previewPane');
    const rendered    = document.getElementById('instructionsRendered');
    const btnEdit     = document.getElementById('btnTabEdit');
    const btnPreview  = document.getElementById('btnTabPreview');

    function renderPreview() {
        rendered.innerHTML = marked.parse(textarea.value || '');
    }

    // Inicia no modo Visualizar
    renderPreview();

    btnEdit.addEventListener('click', function () {
        editPane.classList.remove('hidden');
        previewPane.classList.add('hidden');
        btnEdit.classList.add('bg-brand-600', 'text-white');
        btnEdit.classList.remove('text-slate-500');
        btnPreview.classList.remove('bg-brand-600', 'text-white');
        btnPreview.classList.add('text-slate-500');
    });

    btnPreview.addEventListener('click', function () {
        renderPreview();
        previewPane.classList.remove('hidden');
        editPane.classList.add('hidden');
        btnPreview.classList.add('bg-brand-600', 'text-white');
        btnPreview.classList.remove('text-slate-500');
        btnEdit.classList.remove('bg-brand-600', 'text-white');
        btnEdit.classList.add('text-slate-500');
    });

    // ── Backlog tool select ───────────────────────────────────────
    const ts = new TomSelect('#backlogToolSelect', {
        allowEmptyOption: true,
        onChange: function (val) {
            if (!val) return;
            const opt = document.querySelector(`#backlogToolSelect option[value="${val}"]`);
            if (opt && opt.dataset.instructions) {
                textarea.value = opt.dataset.instructions;
                renderPreview();
            }
        }
    });

    document.getElementById('btnCreateTool').addEventListener('click', async function () {
        const name = document.getElementById('newToolName').value.trim();
        const instructions = document.getElementById('newToolInstructions').value.trim();
        const errEl = document.getElementById('newToolError');

        if (!name) {
            errEl.textContent = 'Enter the tool name.';
            errEl.classList.remove('hidden');
            return;
        }
        errEl.classList.add('hidden');

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const fd = new FormData();
        fd.append('__RequestVerificationToken', token);
        fd.append('Name', name);
        fd.append('DefaultInstructions', instructions);

        try {
            const resp = await fetch('@Url.Action("CreateBacklogTool")', { method: 'POST', body: fd });
            const data = await resp.json();
            ts.addOption({ value: data.id, text: data.name, 'data-instructions': data.defaultInstructions });
            ts.setValue(data.id);
            textarea.value = data.defaultInstructions;
            renderPreview();
            document.getElementById('newToolName').value = '';
        } catch {
            errEl.textContent = 'Error creating tool. Please try again.';
            errEl.classList.remove('hidden');
        }
    });
})();
</script>
}
