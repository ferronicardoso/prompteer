@using Prompteer.Web.Models
@model WizardViewModel
@{
    ViewData["Title"] = "Prompt Generator — Step 8: Rules";
    var ruleFlags = Model.Data.RuleFlags;
    var predefinedRules = new[]
    {
        "Plan before coding",
        "Confirm after each implemented module",
        "Never skip steps without confirmation",
        "Ask before implementing ambiguities",
        "Do not modify files unrelated to the task",
        "Strictly follow the defined patterns"
    };
    var ruleSuggestions = new[]
    {
        "Use comments only when necessary for clarity.",
        "Prefer simple and direct solutions — no over-engineering.",
        "Create tests for each implemented feature.",
        "Document important architectural decisions."
    };
}

<div class="max-w-3xl">
    <partial name="_StepLayout" model="Model" />

    <div class="mb-6">
        <h1 class="text-xl font-semibold text-slate-900">Step 8 — Rules</h1>
        <p class="text-sm text-slate-500 mt-1">Define the agent behavior rules and constraints.</p>
    </div>

    <form method="post" asp-action="Step" asp-route-step="8" asp-route-draftId="@Model.DraftId">
        @Html.AntiForgeryToken()

        <div class="card space-y-6">
            <!-- Predefined Rule Flags -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-3">Behavior Rules</label>
                <div class="space-y-3">
                    @foreach (var rule in predefinedRules)
                    {
                        <label class="flex items-start gap-3 cursor-pointer group">
                            <input type="checkbox" name="RuleFlags" value="@rule"
                                   @(ruleFlags.Contains(rule) ? "checked" : "")
                                   class="w-4 h-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500 mt-0.5 flex-shrink-0" />
                            <span class="text-sm text-slate-700 group-hover:text-slate-900">@rule</span>
                        </label>
                    }
                </div>
            </div>

            <!-- Additional Rules -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Additional Rules</label>
                <textarea id="additionalRules" name="AdditionalRules" rows="6" class="form-textarea w-full"
                          placeholder="Add custom rules here...">@Model.Data.AdditionalRules</textarea>
                <div class="flex flex-wrap gap-2 mt-2">
                    @foreach (var s in ruleSuggestions)
                    {
                        <button type="button"
                                class="rule-chip text-xs px-3 py-1 rounded-full border border-slate-300 text-slate-600 hover:border-brand-400 hover:text-brand-700 hover:bg-brand-50 transition-colors"
                                data-text="@s">@s</button>
                    }
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-between mt-6">
            <button type="submit" formaction="@Url.Action("Previous", new { step = 8, draftId = Model.DraftId })" class="btn btn-secondary">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                Voltar
            </button>
            <button type="submit" class="btn btn-primary">
                <i data-lucide="wand-2" class="w-4 h-4"></i>
                Generate Prompt
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
document.querySelectorAll('.rule-chip').forEach(function (chip) {
    chip.addEventListener('click', function () {
        const ta = document.getElementById('additionalRules');
        const text = chip.dataset.text;
        if (ta.value && !ta.value.endsWith('\n')) ta.value += '\n';
        ta.value += '- ' + text + '\n';
    });
});
</script>
}
