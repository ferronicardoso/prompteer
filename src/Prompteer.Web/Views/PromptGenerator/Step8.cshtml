@using Prompteer.Web.Models
@model WizardViewModel
@{
    ViewData["Title"] = "Gerador de Prompts — Passo 8: Regras";
    var ruleFlags = Model.Data.RuleFlags;
    var predefinedRules = new[]
    {
        "Planeje antes de codar",
        "Confirme após cada módulo implementado",
        "Nunca pule etapas sem confirmação",
        "Pergunte antes de implementar ambiguidades",
        "Não modifique arquivos não relacionados à tarefa",
        "Siga rigorosamente os padrões definidos"
    };
    var ruleSuggestions = new[]
    {
        "Utilize comentários apenas quando necessário para clareza.",
        "Prefira soluções simples e diretas — sem over-engineering.",
        "Crie testes para cada funcionalidade implementada.",
        "Documente decisões arquiteturais importantes."
    };
}

<div class="max-w-3xl">
    <partial name="_StepLayout" model="Model" />

    <div class="mb-6">
        <h1 class="text-xl font-semibold text-slate-900">Passo 8 — Regras</h1>
        <p class="text-sm text-slate-500 mt-1">Defina as regras de comportamento e restrições do agente.</p>
    </div>

    <form method="post" asp-action="Step" asp-route-step="8" asp-route-draftId="@Model.DraftId">
        @Html.AntiForgeryToken()

        <div class="card space-y-6">
            <!-- Predefined Rule Flags -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-3">Regras de Comportamento</label>
                <div class="space-y-3">
                    @foreach (var rule in predefinedRules)
                    {
                        <label class="flex items-start gap-3 cursor-pointer group">
                            <input type="checkbox" name="RuleFlags" value="@rule"
                                   @(ruleFlags.Contains(rule) ? "checked" : "")
                                   class="w-4 h-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500 mt-0.5 flex-shrink-0" />
                            <span class="text-sm text-slate-700 group-hover:text-slate-900">@rule</span>
                        </label>
                    }
                </div>
            </div>

            <!-- Additional Rules -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Regras Adicionais</label>
                <textarea id="additionalRules" name="AdditionalRules" rows="6" class="form-textarea w-full"
                          placeholder="Adicione regras personalizadas aqui...">@Model.Data.AdditionalRules</textarea>
                <div class="flex flex-wrap gap-2 mt-2">
                    @foreach (var s in ruleSuggestions)
                    {
                        <button type="button"
                                class="rule-chip text-xs px-3 py-1 rounded-full border border-slate-300 text-slate-600 hover:border-brand-400 hover:text-brand-700 hover:bg-brand-50 transition-colors"
                                data-text="@s">@s</button>
                    }
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-between mt-6">
            <button type="submit" formaction="@Url.Action("Previous", new { step = 8, draftId = Model.DraftId })" class="btn btn-secondary">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                Voltar
            </button>
            <button type="submit" class="btn btn-primary">
                <i data-lucide="wand-2" class="w-4 h-4"></i>
                Gerar Prompt
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
document.querySelectorAll('.rule-chip').forEach(function (chip) {
    chip.addEventListener('click', function () {
        const ta = document.getElementById('additionalRules');
        const text = chip.dataset.text;
        if (ta.value && !ta.value.endsWith('\n')) ta.value += '\n';
        ta.value += '- ' + text + '\n';
    });
});
</script>
}
