@using Prompteer.Web.Models
@using Prompteer.Application.DTOs
@model WizardViewModel
@{
    ViewData["Title"] = "Prompt Generator — Step 1: Agent";
    var selectedId = Model.Data.AgentProfileId?.ToString() ?? "";
}

<div class="max-w-3xl">
    <partial name="_StepLayout" model="Model" />

    <div class="mb-6">
        <h1 class="text-xl font-semibold text-slate-900">@L["PromptGenerator.Step1.Title"]</h1>
        <p class="text-sm text-slate-500 mt-1">@L["PromptGenerator.Step1.Subtitle"]</p>
    </div>

    <form method="post" asp-action="Step" asp-route-step="1" asp-route-draftId="@Model.DraftId">
        @Html.AntiForgeryToken()

        <div class="card space-y-6">
            <!-- Agent Profile Select -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">@L["PromptGenerator.Step1.AgentProfile"]</label>
                <select id="agentProfileSelect" name="AgentProfileId" class="form-select w-full">
                    <option value="">@L["PromptGenerator.Step1.SelectProfile"]</option>
                    @foreach (var profile in Model.AgentProfiles)
                    {
                        <option value="@profile.Id"
                                data-role="@profile.Role"
                                data-domain="@profile.KnowledgeDomain"
                                data-tone="@profile.ToneDisplay"
                                data-constraints="@profile.DefaultConstraints"
                                selected="@(profile.Id.ToString() == selectedId ? "selected" : null)">
                            @profile.Name
                        </option>
                    }
                </select>
            </div>

            <!-- Profile Detail Panel -->
            <div id="agentDetailPanel" class="hidden rounded-lg border border-brand-200 bg-brand-50 p-4 space-y-2">
                <div class="flex items-center gap-2 mb-2">
                    <i data-lucide="bot" class="w-4 h-4 text-brand-600"></i>
                    <span class="text-sm font-semibold text-brand-700" id="detailName"></span>
                </div>
                <div class="grid grid-cols-2 gap-3 text-xs">
                    <div>
                        <span class="font-medium text-slate-600">@L["Common.Role"]:</span>
                        <p class="text-slate-700 mt-0.5" id="detailRole"></p>
                    </div>
                    <div>
                        <span class="font-medium text-slate-600">@L["AgentProfiles.KnowledgeDomain"]:</span>
                        <p class="text-slate-700 mt-0.5" id="detailDomain"></p>
                    </div>
                    <div>
                        <span class="font-medium text-slate-600">@L["Common.Tone"]:</span>
                        <p class="text-slate-700 mt-0.5" id="detailTone"></p>
                    </div>
                    <div>
                        <span class="font-medium text-slate-600">@L["AgentProfiles.DefaultConstraints"]:</span>
                        <p class="text-slate-700 mt-0.5 whitespace-pre-wrap" id="detailConstraints"></p>
                    </div>
                </div>
            </div>

            <!-- Inline Create Agent Profile -->
            <div x-data="{ open: false }" class="border border-slate-200 rounded-lg">
                <button type="button" @@click="open = !open"
                        class="w-full flex items-center gap-2 px-4 py-3 text-sm text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg transition-colors">
                    <i data-lucide="plus-circle" class="w-4 h-4 text-brand-600"></i>
                    <span>@L["PromptGenerator.Step1.CreateNew"]</span>
                    <i data-lucide="chevron-down" class="w-3.5 h-3.5 ml-auto transition-transform" :class="open && 'rotate-180'"></i>
                </button>

                <div x-show="open" x-collapse class="border-t border-slate-200 p-4 space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-slate-700 mb-1">@L["Common.Name"] <span class="text-red-500">*</span></label>
                            <input id="newAgentName" type="text" class="form-input w-full" placeholder="Ex: Senior .NET Architect" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-700 mb-1">@L["Common.Tone"] <span class="text-red-500">*</span></label>
                            <select id="newAgentTone" class="form-select w-full">
                                <option value="0">Technical</option>
                                <option value="1">Didactic</option>
                                <option value="2">Direct</option>
                                <option value="3">Detailed</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-700 mb-1">@L["Common.Role"] <span class="text-red-500">*</span></label>
                        <textarea id="newAgentRole" rows="2" class="form-textarea w-full" placeholder="Describe the role of this agent..."></textarea>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-700 mb-1">@L["AgentProfiles.KnowledgeDomain"] <span class="text-red-500">*</span></label>
                        <input id="newAgentDomain" type="text" class="form-input w-full" placeholder="Ex: .NET Architecture, DDD, Clean Architecture" />
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-700 mb-1">@L["AgentProfiles.DefaultConstraints"] <span class="text-red-500">*</span></label>
                        <textarea id="newAgentConstraints" rows="3" class="form-textarea w-full" placeholder="Describe the constraints and guidelines..."></textarea>
                    </div>
                    <div id="newAgentError" class="hidden text-xs text-red-600"></div>
                    <button type="button" id="btnCreateAgent" class="btn btn-primary text-sm">
                        <i data-lucide="save" class="w-3.5 h-3.5"></i>
                        @L["PromptGenerator.Step1.CreateProfile"]
                    </button>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-end gap-3 mt-6">
            <button type="submit" class="btn btn-primary">
                @L["PromptGenerator.Next"]
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
(function () {
    // Tom Select
    const ts = new TomSelect('#agentProfileSelect', {
        placeholder: '@L["PromptGenerator.Step1.SelectProfile"]',
        allowEmptyOption: true,
        onChange: showDetail
    });

    function showDetail(val) {
        const panel = document.getElementById('agentDetailPanel');
        if (!val) { panel.classList.add('hidden'); return; }
        const opt = document.querySelector(`#agentProfileSelect option[value="${val}"]`);
        if (!opt) { panel.classList.add('hidden'); return; }
        document.getElementById('detailName').textContent = opt.textContent.trim();
        document.getElementById('detailRole').textContent = opt.dataset.role || '';
        document.getElementById('detailDomain').textContent = opt.dataset.domain || '';
        document.getElementById('detailTone').textContent = opt.dataset.tone || '';
        document.getElementById('detailConstraints').textContent = opt.dataset.constraints || '';
        panel.classList.remove('hidden');
    }

    // Show detail for pre-selected value
    if (ts.getValue()) showDetail(ts.getValue());

    // Create agent profile AJAX
    document.getElementById('btnCreateAgent').addEventListener('click', async function () {
        const name = document.getElementById('newAgentName').value.trim();
        const role = document.getElementById('newAgentRole').value.trim();
        const domain = document.getElementById('newAgentDomain').value.trim();
        const tone = parseInt(document.getElementById('newAgentTone').value);
        const constraints = document.getElementById('newAgentConstraints').value.trim();
        const errEl = document.getElementById('newAgentError');

        if (!name || !role || !domain || !constraints) {
            errEl.textContent = 'Fill in all required fields.';
            errEl.classList.remove('hidden');
            return;
        }
        errEl.classList.add('hidden');

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const fd = new FormData();
        fd.append('__RequestVerificationToken', token);
        fd.append('Name', name);
        fd.append('Role', role);
        fd.append('KnowledgeDomain', domain);
        fd.append('Tone', tone);
        fd.append('DefaultConstraints', constraints);

        try {
            const resp = await fetch('@Url.Action("CreateAgentProfile")', { method: 'POST', body: fd });
            const data = await resp.json();
            ts.addOption({
                value: data.id,
                text: data.name,
                'data-role': data.role,
                'data-domain': data.knowledgeDomain,
                'data-tone': data.toneDisplay,
                'data-constraints': data.defaultConstraints
            });
            ts.setValue(data.id);

            // Reset form
            document.getElementById('newAgentName').value = '';
            document.getElementById('newAgentRole').value = '';
            document.getElementById('newAgentDomain').value = '';
            document.getElementById('newAgentConstraints').value = '';
        } catch {
            errEl.textContent = 'Error creating profile. Please try again.';
            errEl.classList.remove('hidden');
        }
    });
})();
</script>
}
