@using Prompteer.Web.Models
@inject Prompteer.Application.Services.IAIService AiService
@model WizardViewModel
@{
    ViewData["Title"] = "Prompt Generator — Step 4: Architecture";
    var selectedPatternIds = Model.Data.ArchitecturalPatternIds.Select(id => id.ToString()).ToHashSet();
    var packagesJson = System.Text.Json.JsonSerializer.Serialize(Model.Data.RequiredPackages);
    var aiConfigured = await AiService.IsConfiguredAsync();
}

<div class="max-w-3xl">
    <partial name="_StepLayout" model="Model" />

    <div class="mb-6">
        <h1 class="text-xl font-semibold text-slate-900">@L["PromptGenerator.Step4.Title"]</h1>
        <p class="text-sm text-slate-500 mt-1">@L["PromptGenerator.Step4.Subtitle"]</p>
    </div>

    <form method="post" asp-action="Step" asp-route-step="4" asp-route-draftId="@Model.DraftId">
        @Html.AntiForgeryToken()

        <div class="card space-y-6">
            <!-- Architectural Patterns -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">@L["PromptGenerator.Step4.ArchitecturalPatterns"]</label>
                <select id="patternSelect" name="ArchitecturalPatternIds" multiple class="form-select w-full">
                    @foreach (var pattern in Model.ArchitecturalPatterns)
                    {
                        <option value="@pattern.Id"
                                data-description="@pattern.Description"
                                selected="@(selectedPatternIds.Contains(pattern.Id.ToString()) ? "selected" : null)">
                            @pattern.Name (@pattern.EcosystemDisplay)
                        </option>
                    }
                </select>
            </div>

            <!-- Inline Create Pattern -->
            <div x-data="{ open: false }" class="border border-slate-200 rounded-lg">
                <button type="button" @@click="open = !open"
                        class="w-full flex items-center gap-2 px-4 py-3 text-sm text-slate-600 hover:text-slate-900 hover:bg-slate-50 rounded-lg transition-colors">
                    <i data-lucide="plus-circle" class="w-4 h-4 text-brand-600"></i>
                    <span>@L["PromptGenerator.Step4.AddNewPattern"]</span>
                    <i data-lucide="chevron-down" class="w-3.5 h-3.5 ml-auto transition-transform" :class="open && 'rotate-180'"></i>
                </button>
                <div x-show="open" x-collapse class="border-t border-slate-200 p-4 space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-slate-700 mb-1">@L["Common.Name"] <span class="text-red-500">*</span></label>
                            <input id="newPatternName" type="text" class="form-input w-full" placeholder="Ex: Clean Architecture, DDD, CQRS" />
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-slate-700 mb-1">@L["Common.Ecosystem"] <span class="text-red-500">*</span></label>
                            <select id="newPatternEcosystem" class="form-select w-full">
                                <option value="0">.NET</option>
                                <option value="1">Node.js</option>
                                <option value="2">Python</option>
                                <option value="3">Java</option>
                                <option value="4">Agnostic</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-700 mb-1">@L["Common.Description"] <span class="text-red-500">*</span></label>
                        <textarea id="newPatternDesc" rows="2" class="form-textarea w-full" placeholder="Describe the architectural pattern..."></textarea>
                    </div>
                    <div id="newPatternError" class="hidden text-xs text-red-600"></div>
                    <button type="button" id="btnCreatePattern" class="btn btn-primary text-sm">
                        <i data-lucide="save" class="w-3.5 h-3.5"></i>
                        @L["PromptGenerator.Step4.AddPattern"]
                    </button>
                </div>
            </div>

            <!-- Required Packages -->
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">@L["PromptGenerator.Step4.RequiredPackages"]</label>
                <select id="packagesSelect" name="RequiredPackages" multiple class="form-select w-full">
                    @foreach (var pkg in Model.Data.RequiredPackages)
                    {
                        <option value="@pkg" selected>@pkg</option>
                    }
                </select>
                <p class="text-xs text-slate-400 mt-1">@L["PromptGenerator.Step4.PackagesNote"]</p>
            </div>

            <!-- Code Conventions -->
            <div>
                <div class="flex items-center justify-between mb-1">
                    <label class="text-sm font-medium text-slate-700">@L["PromptGenerator.Step4.CodeConventions"]</label>
                    @if (aiConfigured)
                    {
                        <button type="button"
                                onclick="aiGenerate('codeConventions','CodeConventions',{name:_s4ProjName,extra:'Patterns: '+Array.from(document.querySelectorAll('#patternSelect option:checked')).map(o=>o.text).join(', ')+'. Packages: '+Array.from(document.querySelectorAll('#packagesSelect option:checked')).map(o=>o.text).join(', ')},this)"
                                class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-violet-50 text-violet-700 border border-violet-200 hover:bg-violet-100 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                title="@L["Common.GenerateWithAI"]">
                            <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
                            @L["Common.GenerateWithAI"]
                        </button>
                    }
                </div>
                <textarea id="codeConventions" name="CodeConventions" rows="5" class="form-textarea w-full"
                          placeholder="Describe the code conventions to follow...">@Model.Data.CodeConventions</textarea>
                <div class="flex flex-wrap gap-2 mt-2">
                    @{
                        var suggestions = new[]
                        {
                            "Use async/await throughout the application",
                            "Follow C# naming conventions (PascalCase for types, camelCase for variables)",
                            "Document public methods with XML comments",
                            "Avoid magic numbers and string literals"
                        };
                    }
                    @foreach (var s in suggestions)
                    {
                        <button type="button" class="suggestion-chip text-xs px-3 py-1 rounded-full border border-slate-300 text-slate-600 hover:border-brand-400 hover:text-brand-700 hover:bg-brand-50 transition-colors"
                                data-text="@s">@s</button>
                    }
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-between mt-6">
            <button type="submit" formaction="@Url.Action("Previous", new { step = 4, draftId = Model.DraftId })" class="btn btn-secondary">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                @L["PromptGenerator.Back"]
            </button>
            <button type="submit" class="btn btn-primary">
                @L["PromptGenerator.Next"]
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </button>
        </div>
    </form>
</div>

@section Scripts {
<script>
const _s4ProjName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.ProjectName ?? ""));
(function () {
    // Architectural patterns Tom Select
    new TomSelect('#patternSelect', {
        plugins: ['remove_button'],
        placeholder: '@L["PromptGenerator.Step4.SelectPatterns"]',
        closeAfterSelect: false
    });

    // Required packages — tags mode
    new TomSelect('#packagesSelect', {
        plugins: ['remove_button'],
        create: true,
        placeholder: '@L["PromptGenerator.Step4.SelectPackages"]',
        createOnBlur: true
    });

    // Code conventions suggestion chips
    document.querySelectorAll('.suggestion-chip').forEach(function (chip) {
        chip.addEventListener('click', function () {
            const ta = document.getElementById('codeConventions');
            const text = chip.dataset.text;
            if (ta.value && !ta.value.endsWith('\n')) ta.value += '\n';
            ta.value += '- ' + text + '\n';
        });
    });

    // Create architectural pattern AJAX
    document.getElementById('btnCreatePattern').addEventListener('click', async function () {
        const name = document.getElementById('newPatternName').value.trim();
        const desc = document.getElementById('newPatternDesc').value.trim();
        const ecosystem = parseInt(document.getElementById('newPatternEcosystem').value);
        const errEl = document.getElementById('newPatternError');

        if (!name || !desc) {
            errEl.textContent = 'Fill in name and description.';
            errEl.classList.remove('hidden');
            return;
        }
        errEl.classList.add('hidden');

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const fd = new FormData();
        fd.append('__RequestVerificationToken', token);
        fd.append('Name', name);
        fd.append('Description', desc);
        fd.append('Ecosystem', ecosystem);

        try {
            const resp = await fetch('@Url.Action("CreateArchitecturalPattern")', { method: 'POST', body: fd });
            const data = await resp.json();
            const ts = document.getElementById('patternSelect').tomselect;
            ts.addOption({ value: data.id, text: `${data.name} (${data.ecosystemDisplay})` });
            ts.addItem(data.id);
            document.getElementById('newPatternName').value = '';
            document.getElementById('newPatternDesc').value = '';
        } catch {
            errEl.textContent = 'Error adding pattern. Please try again.';
            errEl.classList.remove('hidden');
        }
    });
})();
</script>
}
