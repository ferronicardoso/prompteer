@using Prompteer.Web.Models
@model WizardViewModel
@{
    ViewData["Title"] = "Prompt Generator — Step 6: Tests";
    var testTypes = Model.Data.TestTypes;
    var allTestTypes = new[] { "Unit", "Integration", "E2E" };
    var frameworkSuggestions = new[] { "xUnit", "NUnit", "MSTest", "Pytest", "Jest" };
}

<div class="max-w-3xl">
    <partial name="_StepLayout" model="Model" />

    <div class="mb-6">
        <h1 class="text-xl font-semibold text-slate-900">@L["PromptGenerator.Step6.Title"]</h1>
        <p class="text-sm text-slate-500 mt-1">@L["PromptGenerator.Step6.Subtitle"]</p>
    </div>

    <form method="post" asp-action="Step" asp-route-step="6" asp-route-draftId="@Model.DraftId"
          x-data="{ active: @(Model.Data.IncludeTests ? "true" : "false") }">
        @Html.AntiForgeryToken()
        <input type="hidden" name="IncludeTests" :value="active ? 'true' : 'false'" />

        <div class="card space-y-6">
            <!-- Toggle -->
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-slate-700">@L["PromptGenerator.Step6.IncludeToggle"]</p>
                    <p class="text-xs text-slate-500">@L["PromptGenerator.Step5.DisableNote"]</p>
                </div>
                <button type="button" @@click="active = !active"
                        class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none"
                        :class="active ? 'bg-brand-600' : 'bg-slate-300'">
                    <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform shadow"
                          :class="active ? 'translate-x-6' : 'translate-x-1'"></span>
                </button>
            </div>

            <div x-show="active" x-transition class="space-y-6">
                <!-- Test Types -->
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-3">@L["PromptGenerator.Step6.TestTypes"]</label>
                    <div class="flex flex-wrap gap-4">
                        @foreach (var type in allTestTypes)
                        {
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" name="TestTypes" value="@type"
                                       @(testTypes.Contains(type) ? "checked" : "")
                                       class="w-4 h-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" />
                                <span class="text-sm text-slate-700">@type</span>
                            </label>
                        }
                    </div>
                </div>

                <!-- Test Framework -->
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">@L["PromptGenerator.Step6.TestFramework"]</label>
                    <input id="testFramework" type="text" name="TestFramework" value="@Model.Data.TestFramework"
                           class="form-input w-full" placeholder="Ex: xUnit, NUnit, Pytest, Jest" />
                    <div class="flex flex-wrap gap-2 mt-2">
                        @foreach (var fw in frameworkSuggestions)
                        {
                            <button type="button"
                                    class="framework-chip text-xs px-3 py-1 rounded-full border border-slate-300 text-slate-600 hover:border-brand-400 hover:text-brand-700 hover:bg-brand-50 transition-colors"
                                    data-value="@fw">@fw</button>
                        }
                    </div>
                </div>

                <!-- Min Coverage -->
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">@L["PromptGenerator.Step6.MinCoverage"]</label>
                    <input type="number" name="MinCoverage" min="0" max="100"
                           value="@(Model.Data.MinCoverage?.ToString() ?? "80")"
                           class="form-input w-32" placeholder="80" />
                </div>

                <!-- Test Observations -->
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">@L["PromptGenerator.Step6.TestObservations"]</label>
                    <textarea name="TestObservations" rows="4" class="form-textarea w-full"
                              placeholder="Additional guidelines on the testing strategy...">@Model.Data.TestObservations</textarea>
                </div>
            </div>
        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-between mt-6">
            <button type="submit" formaction="@Url.Action("Previous", new { step = 6, draftId = Model.DraftId })" class="btn btn-secondary">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                @L["PromptGenerator.Back"]
            </button>
            <div class="flex gap-3">
                <button type="submit" x-show="!active"
                        class="btn btn-ghost text-slate-500 hover:text-slate-700">
                    @L["PromptGenerator.SkipStep"]
                    <i data-lucide="skip-forward" class="w-4 h-4"></i>
                </button>
                <button type="submit" class="btn btn-primary">
                    @L["PromptGenerator.Next"]
                    <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
<script>
document.querySelectorAll('.framework-chip').forEach(function (chip) {
    chip.addEventListener('click', function () {
        document.getElementById('testFramework').value = chip.dataset.value;
    });
});
</script>
}
