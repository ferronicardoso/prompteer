@using Prompteer.Application.DTOs
@model ArchitecturalPatternFormDto
@{
    ViewData["Title"] = "Edit Architectural Pattern";
}

<div class="max-w-2xl">
    <!-- Header -->
    <div class="mb-6">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-2">
            <a asp-action="Index" class="hover:text-slate-700">@L["ArchitecturalPatterns.Title"]</a>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
            <span class="text-slate-900">@L["ArchitecturalPatterns.Edit.Breadcrumb"]</span>
        </nav>
        <h1 class="text-xl font-semibold text-slate-900">@L["ArchitecturalPatterns.Edit.Title"]</h1>
    </div>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="card space-y-5">
            <div asp-validation-summary="ModelOnly" class="rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700"></div>

            <!-- Name -->
            <div>
                <label asp-for="Name" class="block text-sm font-medium text-slate-700 mb-1">@L["Common.Name"] <span class="text-red-500">*</span></label>
                <input asp-for="Name" class="form-input w-full" />
                <span asp-validation-for="Name" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            <!-- Description -->
            <div>
                <div class="flex items-center justify-between mb-1">
                    <label asp-for="Description" class="text-sm font-medium text-slate-700">@L["Common.Description"] <span class="text-red-500">*</span></label>
                    <button type="button" onclick="aiGenerate('Description','PatternDescription',{name:document.getElementById('Name').value,ecosystem:document.querySelector('[name=Ecosystem] option:checked')?.text??''},this)" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-violet-50 text-violet-700 border border-violet-200 hover:bg-violet-100 transition-colors"><i data-lucide="sparkles" class="w-3.5 h-3.5"></i> @L["Common.GenerateWithAI"]</button>
                </div>
                <textarea asp-for="Description" rows="4" class="form-textarea w-full"></textarea>
                <span asp-validation-for="Description" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            <!-- Ecosystem -->
            <div>
                <label asp-for="Ecosystem" class="block text-sm font-medium text-slate-700 mb-1">@L["Common.Ecosystem"] <span class="text-red-500">*</span></label>
                <select asp-for="Ecosystem" asp-items="ViewBag.EcosystemItems" class="form-select w-full"></select>
                <span asp-validation-for="Ecosystem" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
                <button type="submit" class="btn btn-primary">
                    <i data-lucide="save" class="w-4 h-4"></i>
                    @L["Common.SaveChanges"]
                </button>
                <a asp-action="Index" class="btn btn-secondary">@L["Common.Cancel"]</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
