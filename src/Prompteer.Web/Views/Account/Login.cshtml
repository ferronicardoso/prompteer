@model Prompteer.Web.Models.LocalLoginViewModel
@{
    ViewData["Title"] = "Entrar";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
    var returnUrl       = ViewBag.ReturnUrl as string ?? "/";
    var error           = ViewBag.Error as string;
    var entraConfigured = (bool)(ViewBag.EntraConfigured ?? false);
    var setupSuccess    = ViewBag.SetupSuccess as string;
}

<div class="min-h-screen flex">

    @* Left panel — Brand *@
    <div class="hidden lg:flex lg:w-1/2 xl:w-[58%] relative flex-col bg-gradient-to-br from-indigo-700 via-indigo-600 to-violet-700 overflow-hidden">
        <div class="absolute -top-32 -left-32 w-96 h-96 bg-indigo-500 rounded-full opacity-30 blur-3xl"></div>
        <div class="absolute -bottom-40 -right-24 w-[28rem] h-[28rem] bg-violet-600 rounded-full opacity-25 blur-3xl"></div>

        <div class="relative z-10 flex flex-col h-full p-12 xl:p-16">
            <div class="flex items-center gap-3 mb-16">
                <div class="w-10 h-10 rounded-xl bg-white/15 backdrop-blur-sm flex items-center justify-center">
                    <i data-lucide="sparkles" class="w-5 h-5 text-white"></i>
                </div>
                <span class="text-2xl font-bold text-white tracking-tight">Prompteer</span>
            </div>

            <div class="flex-1 flex flex-col justify-center max-w-md">
                <h1 class="text-4xl xl:text-5xl font-extrabold text-white leading-tight mb-5">
                    Gere prompts<br />
                    <span class="text-indigo-200">estruturados</span><br />
                    para agentes de IA.
                </h1>
                <p class="text-indigo-100 text-lg leading-relaxed">
                    Construa instruções completas para Claude, GitHub Copilot e outros agentes — de forma rápida, consistente e reutilizável.
                </p>

                <div class="mt-10 space-y-4">
                    @foreach (var feat in new[]
                    {
                        ("sparkles",     "Wizard em 9 etapas",         "Gere prompts detalhados passo a passo"),
                        ("layers",       "Templates versionados",       "Salve, clone e compare versões"),
                        ("cpu",          "Multi-provider AI",           "OpenAI e Anthropic integrados"),
                        ("shield-check", "Acesso seguro via Microsoft", "Autenticação corporativa com Entra ID"),
                    })
                    {
                        <div class="flex items-start gap-3.5">
                            <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                                <i data-lucide="@feat.Item1" class="w-4 h-4 text-indigo-200"></i>
                            </div>
                            <div>
                                <p class="text-white font-semibold text-sm">@feat.Item2</p>
                                <p class="text-indigo-200 text-xs mt-0.5">@feat.Item3</p>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <p class="text-indigo-300 text-xs mt-auto">© @DateTime.UtcNow.Year Prompteer.</p>
        </div>
    </div>

    @* Right panel — Login form *@
    <div class="flex-1 flex flex-col items-center justify-center px-6 sm:px-12 xl:px-20 bg-white">

        <div class="flex lg:hidden items-center gap-2.5 mb-10">
            <div class="w-9 h-9 rounded-xl bg-indigo-600 flex items-center justify-center">
                <i data-lucide="sparkles" class="w-4 h-4 text-white"></i>
            </div>
            <span class="text-xl font-bold text-slate-900">Prompteer</span>
        </div>

        <div class="w-full max-w-sm">
            <div class="mb-7">
                <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">Bem-vindo de volta</h2>
                <p class="text-slate-500 text-sm mt-2">
                    @if (entraConfigured)
                    {
                        <text>Acesse com sua conta Microsoft ou com e-mail e senha.</text>
                    }
                    else
                    {
                        <text>Acesse com seu e-mail e senha de administrador.</text>
                    }
                </p>
            </div>

            @* Setup success banner *@
            @if (setupSuccess is not null)
            {
                <div class="flex items-start gap-3 p-4 mb-5 rounded-xl bg-green-50 border border-green-200 text-green-800 text-sm">
                    <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
                    <div>
                        <p class="font-semibold">Conta criada com sucesso!</p>
                        <p class="mt-0.5 text-green-700">Olá, <strong>@setupSuccess</strong>! Faça login para continuar a configuração.</p>
                    </div>
                </div>
            }

            @* Error *@
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="flex items-start gap-3 p-4 mb-5 rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm">
                    <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
                    <span>@error</span>
                </div>
            }

            @* Entra button (only when configured) *@
            @if (entraConfigured)
            {
                <a href="@Url.Action("SignIn", "Account", new { returnUrl })"
                   class="flex items-center justify-center gap-3 w-full px-5 py-3.5 mb-5 rounded-xl border border-slate-200 bg-white text-slate-700 font-semibold text-sm shadow-sm hover:bg-slate-50 hover:border-slate-300 hover:shadow-md transition-all duration-200">
                    <svg width="20" height="20" viewBox="0 0 21 21" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <rect x="1"  y="1"  width="9" height="9" fill="#F35325"/>
                        <rect x="11" y="1"  width="9" height="9" fill="#81BC06"/>
                        <rect x="1"  y="11" width="9" height="9" fill="#05A6F0"/>
                        <rect x="11" y="11" width="9" height="9" fill="#FFBA08"/>
                    </svg>
                    Entrar com Microsoft
                </a>

                <div class="flex items-center gap-3 mb-5">
                    <div class="h-px flex-1 bg-slate-100"></div>
                    <span class="text-xs text-slate-400">ou com senha local</span>
                    <div class="h-px flex-1 bg-slate-100"></div>
                </div>
            }

            @* Local login form *@
            <form asp-action="LocalLogin" method="post" novalidate class="space-y-4">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" value="@returnUrl" />

                <div asp-validation-summary="ModelOnly"
                     class="p-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm"></div>

                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-slate-700 mb-1.5">E-mail</label>
                    <input asp-for="Email" type="email" placeholder="admin@empresa.com"
                           autocomplete="email"
                           class="w-full px-3.5 py-2.5 text-sm border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                    <span asp-validation-for="Email" class="text-xs text-red-600 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-medium text-slate-700 mb-1.5">Senha</label>
                    <div class="relative" x-data="{ show: false }">
                        <input asp-for="Password"
                               :type="show ? 'text' : 'password'"
                               placeholder="••••••••"
                               autocomplete="current-password"
                               class="w-full px-3.5 py-2.5 pr-10 text-sm border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
                        <button type="button" @@click="show = !show"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                            <i data-lucide="eye" class="w-4 h-4"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-xs text-red-600 mt-1 block"></span>
                </div>

                <button type="submit"
                        class="w-full flex items-center justify-center gap-2 py-3 rounded-xl bg-indigo-600 text-white font-semibold text-sm hover:bg-indigo-700 active:scale-[0.98] transition-all shadow-sm">
                    <i data-lucide="log-in" class="w-4 h-4"></i>
                    Entrar
                </button>
            </form>

            @* Security note *@
            <div class="flex items-center gap-2 mt-7 p-3 rounded-xl bg-slate-50 border border-slate-100">
                <i data-lucide="lock" class="w-4 h-4 text-slate-400 flex-shrink-0"></i>
                <p class="text-xs text-slate-500">
                    @if (entraConfigured)
                    {
                        <text>Login local disponível apenas para o administrador inicial.</text>
                    }
                    else
                    {
                        <text>Configure o <strong>Microsoft Entra ID</strong> nas Configurações após o primeiro acesso.</text>
                    }
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
