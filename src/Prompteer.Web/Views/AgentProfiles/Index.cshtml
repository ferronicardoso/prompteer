@using Prompteer.Application.DTOs
@using Prompteer.Domain.Enums
@model PagedResult<AgentProfileDto>
@{
    ViewData["Title"] = "Perfis de Agente";
    var search = ViewData["Search"]?.ToString() ?? "";
}

<div class="space-y-4">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-xl font-semibold text-slate-900">Perfis de Agente</h1>
            <p class="text-sm text-slate-500 mt-0.5">Gerencie os perfis de comportamento dos agentes de IA</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i data-lucide="plus" class="w-4 h-4"></i>
            Novo Perfil
        </a>
    </div>

    <!-- Search -->
    <form method="get" asp-action="Index" class="flex gap-2">
        <div class="relative flex-1 max-w-sm">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
            <input type="text" name="search" value="@search"
                   placeholder="Buscar por nome ou papel..."
                   class="form-input pl-9 w-full" />
        </div>
        <button type="submit" class="btn btn-secondary">Filtrar</button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a asp-action="Index" class="btn btn-ghost">Limpar</a>
        }
    </form>

    <!-- Table -->
    <div class="card p-0 overflow-hidden">
        @if (!Model.Items.Any())
        {
            <div class="text-center py-16">
                <i data-lucide="bot" class="w-10 h-10 text-slate-300 mx-auto mb-3"></i>
                <p class="text-sm text-slate-500">Nenhum perfil de agente encontrado.</p>
                <a asp-action="Create" class="btn btn-primary btn-sm mt-3">Criar primeiro perfil</a>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-200 bg-slate-50">
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Nome</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Papel</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Tom</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Criado em</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model.Items)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="font-medium text-slate-900 hover:text-brand-600 hover:underline">@item.Name</a>
                                    @if (item.IsSystemDefault)
                                    {
                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600">
                                            <i data-lucide="lock" class="w-3 h-3"></i> Padrão
                                        </span>
                                    }
                                </div>
                            </td>
                            <td class="px-4 py-3 text-slate-600 max-w-xs truncate">@item.Role</td>
                            <td class="px-4 py-3">
                                @{
                                    var toneCss = item.Tone switch
                                    {
                                        ToneType.Technical => "bg-blue-100 text-blue-700",
                                        ToneType.Didactic  => "bg-green-100 text-green-700",
                                        ToneType.Direct    => "bg-red-100 text-red-700",
                                        ToneType.Detailed  => "bg-indigo-100 text-indigo-700",
                                        _                  => "bg-slate-100 text-slate-600"
                                    };
                                }
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium @toneCss">@item.ToneDisplay</span>
                            </td>
                            <td class="px-4 py-3 text-slate-500">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-end gap-1">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-ghost btn-sm">
                                        <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                                        Ver
                                    </a>
                                    @if (item.IsSystemDefault)
                                    {
                                        <form asp-action="Clone" asp-route-id="@item.Id" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-ghost btn-sm">
                                                <i data-lucide="copy" class="w-3.5 h-3.5"></i>
                                                Clonar
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Clone" asp-route-id="@item.Id" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-ghost btn-sm">
                                                <i data-lucide="copy" class="w-3.5 h-3.5"></i>
                                                Clonar
                                            </button>
                                        </form>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-ghost btn-sm">
                                            <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                            Editar
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-ghost btn-sm text-red-600 hover:text-red-700">
                                            <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                                            Excluir
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @await Html.PartialAsync("_Pagination", new PagedResult<dynamic>
            {
                TotalCount = Model.TotalCount,
                Page = Model.Page,
                PageSize = Model.PageSize
            })
        }
    </div>
</div>
