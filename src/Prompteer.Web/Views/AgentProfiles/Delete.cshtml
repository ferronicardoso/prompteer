@using Prompteer.Application.DTOs
@using Prompteer.Domain.Enums
@model AgentProfileDto
@{
    ViewData["Title"] = "Excluir Perfil de Agente";
}

<div class="max-w-lg">
    <!-- Header -->
    <div class="mb-6">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-2">
            <a asp-action="Index" class="hover:text-slate-700">Perfis de Agente</a>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
            <span class="text-slate-900">Excluir</span>
        </nav>
        <h1 class="text-xl font-semibold text-slate-900">Excluir Perfil de Agente</h1>
    </div>

    <div class="card space-y-4">
        <div class="flex items-start gap-3 p-4 rounded-lg bg-red-50 border border-red-200">
            <i data-lucide="alert-triangle" class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5"></i>
            <p class="text-sm text-red-700">
                Tem certeza que deseja excluir o perfil <strong>@Model.Name</strong>? Esta ação não pode ser desfeita.
            </p>
        </div>

        <dl class="divide-y divide-slate-100">
            <div class="py-3 flex gap-4">
                <dt class="w-40 flex-shrink-0 text-sm font-medium text-slate-500">Nome</dt>
                <dd class="text-sm text-slate-900">@Model.Name</dd>
            </div>
            <div class="py-3 flex gap-4">
                <dt class="w-40 flex-shrink-0 text-sm font-medium text-slate-500">Papel</dt>
                <dd class="text-sm text-slate-900">@Model.Role</dd>
            </div>
            <div class="py-3 flex gap-4">
                <dt class="w-40 flex-shrink-0 text-sm font-medium text-slate-500">Tom</dt>
                <dd class="text-sm text-slate-900">@Model.ToneDisplay</dd>
            </div>
            <div class="py-3 flex gap-4">
                <dt class="w-40 flex-shrink-0 text-sm font-medium text-slate-500">Criado em</dt>
                <dd class="text-sm text-slate-900">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
            </div>
        </dl>

        <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                    Confirmar Exclusão
                </button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </div>
</div>
