@using Prompteer.Application.DTOs
@using Prompteer.Domain.Enums
@model AgentProfileDto
@{
    ViewData["Title"] = Model.Name;
    var toneCss = Model.Tone switch
    {
        ToneType.Technical => "bg-blue-100 text-blue-700",
        ToneType.Didactic  => "bg-green-100 text-green-700",
        ToneType.Direct    => "bg-red-100 text-red-700",
        ToneType.Detailed  => "bg-indigo-100 text-indigo-700",
        _                  => "bg-slate-100 text-slate-600"
    };
}

<div class="max-w-2xl">
    <!-- Header -->
    <div class="mb-6">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-2">
            <a asp-action="Index" class="hover:text-slate-700">@L["AgentProfiles.Title"]</a>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
            <span class="text-slate-900">@Model.Name</span>
        </nav>
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <h1 class="text-xl font-semibold text-slate-900">@Model.Name</h1>
                @if (Model.IsSystemDefault)
                {
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600">
                        <i data-lucide="lock" class="w-3 h-3"></i> @L["AgentProfiles.SystemDefault"]
                    </span>
                }
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium @toneCss">@Model.ToneDisplay</span>
            </div>
            <div class="flex items-center gap-2">
                <!-- Clone -->
                <form asp-action="Clone" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-secondary btn-sm">
                        <i data-lucide="copy" class="w-3.5 h-3.5"></i>
                        @L["Common.Clone"]
                    </button>
                </form>
                @if (!Model.IsSystemDefault)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                        <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                        @L["Common.Edit"]
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="card space-y-5">
        <!-- Role -->
        <div>
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">@L["Common.Role"]</p>
            <div class="prose prose-sm max-w-none text-slate-700 whitespace-pre-wrap">@Model.Role</div>
        </div>

        <hr class="border-slate-100" />

        <!-- Knowledge Domain -->
        <div>
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">@L["AgentProfiles.KnowledgeDomain"]</p>
            <p class="text-sm text-slate-700">@Model.KnowledgeDomain</p>
        </div>

        <hr class="border-slate-100" />

        <!-- Default Constraints -->
        <div>
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">@L["AgentProfiles.DefaultConstraints"]</p>
            <div class="prose prose-sm max-w-none text-slate-700 whitespace-pre-wrap">@Model.DefaultConstraints</div>
        </div>

        <hr class="border-slate-100" />

        <!-- Metadata -->
        <div class="flex items-center gap-6 text-xs text-slate-400">
            <span>@L["AgentProfiles.CreatedOn"] <strong class="text-slate-500">@Model.CreatedAt.ToString((string)ViewData["DateFormat"]!)</strong></span>
            <span>@L["AgentProfiles.UpdatedOn"] <strong class="text-slate-500">@Model.UpdatedAt.ToString((string)ViewData["DateTimeFormat"]!)</strong></span>
        </div>
    </div>

    @if (!Model.IsSystemDefault)
    {
        <div class="mt-4 flex justify-end">
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-ghost btn-sm text-red-600 hover:text-red-700">
                <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                @L["AgentProfiles.DeleteProfile"]
            </a>
        </div>
    }
</div>
