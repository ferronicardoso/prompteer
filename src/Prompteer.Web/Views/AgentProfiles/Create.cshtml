@using Prompteer.Application.DTOs
@model AgentProfileFormDto
@{
    ViewData["Title"] = "New Agent Profile";
}

<div class="max-w-2xl">
    <!-- Header -->
    <div class="mb-6">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-2">
            <a asp-action="Index" class="hover:text-slate-700">@L["AgentProfiles.Title"]</a>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
            <span class="text-slate-900">@L["AgentProfiles.Create.Breadcrumb"]</span>
        </nav>
        <h1 class="text-xl font-semibold text-slate-900">@L["AgentProfiles.Create.Title"]</h1>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="card space-y-5">
            <div asp-validation-summary="ModelOnly" class="rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700"></div>

            <!-- Name -->
            <div>
                <label asp-for="Name" class="block text-sm font-medium text-slate-700 mb-1">@L["Common.Name"] <span class="text-red-500">*</span></label>
                <input asp-for="Name" class="form-input w-full" placeholder="@L["AgentProfiles.NamePlaceholder"]" />
                <span asp-validation-for="Name" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            <!-- Role -->
            <div>
                <div class="flex items-center justify-between mb-1">
                    <label asp-for="Role" class="text-sm font-medium text-slate-700">@L["Common.Role"] <span class="text-red-500">*</span></label>
                    <button type="button" onclick="aiGenerate('Role','AgentRole',{name:document.getElementById('Name').value,tone:document.querySelector('[name=Tone] option:checked')?.text??''},this)" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-violet-50 text-violet-700 border border-violet-200 hover:bg-violet-100 transition-colors"><i data-lucide="sparkles" class="w-3.5 h-3.5"></i> @L["Common.GenerateWithAI"]</button>
                </div>
                <textarea asp-for="Role" rows="3" class="form-textarea w-full" placeholder="@L["AgentProfiles.RolePlaceholder"]"></textarea>
                <span asp-validation-for="Role" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            <!-- Knowledge Domain -->
            <div>
                <div class="flex items-center justify-between mb-1">
                    <label asp-for="KnowledgeDomain" class="text-sm font-medium text-slate-700">@L["AgentProfiles.KnowledgeDomain"] <span class="text-red-500">*</span></label>
                    <button type="button" onclick="aiGenerate('KnowledgeDomain','AgentKnowledgeDomain',{name:document.getElementById('Name').value,tone:document.querySelector('[name=Tone] option:checked')?.text??''},this)" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-violet-50 text-violet-700 border border-violet-200 hover:bg-violet-100 transition-colors"><i data-lucide="sparkles" class="w-3.5 h-3.5"></i> @L["Common.GenerateWithAI"]</button>
                </div>
                <input asp-for="KnowledgeDomain" class="form-input w-full" placeholder="@L["AgentProfiles.KnowledgeDomainPlaceholder"]" />
                <span asp-validation-for="KnowledgeDomain" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            <!-- Tone -->
            <div>
                <label asp-for="Tone" class="block text-sm font-medium text-slate-700 mb-1">@L["Common.Tone"] <span class="text-red-500">*</span></label>
                <select asp-for="Tone" asp-items="ViewBag.ToneItems" class="form-select w-full"></select>
                <span asp-validation-for="Tone" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            <!-- Default Constraints -->
            <div>
                <div class="flex items-center justify-between mb-1">
                    <label asp-for="DefaultConstraints" class="text-sm font-medium text-slate-700">@L["AgentProfiles.DefaultConstraints"] <span class="text-red-500">*</span></label>
                    <button type="button" onclick="aiGenerate('DefaultConstraints','AgentConstraints',{name:document.getElementById('Name').value,tone:document.querySelector('[name=Tone] option:checked')?.text??'',role:document.getElementById('Role').value},this)" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-violet-50 text-violet-700 border border-violet-200 hover:bg-violet-100 transition-colors"><i data-lucide="sparkles" class="w-3.5 h-3.5"></i> @L["Common.GenerateWithAI"]</button>
                </div>
                <textarea asp-for="DefaultConstraints" rows="4" class="form-textarea w-full" placeholder="@L["AgentProfiles.ConstraintsPlaceholder"]"></textarea>
                <span asp-validation-for="DefaultConstraints" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
                <button type="submit" class="btn btn-primary">
                    <i data-lucide="save" class="w-4 h-4"></i>
                    @L["Common.Save"]
                </button>
                <a asp-action="Index" class="btn btn-secondary">@L["Common.Cancel"]</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
