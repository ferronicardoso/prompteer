@model Prompteer.Application.DTOs.DashboardStatsDto
@{
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-6">

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">

        <div class="card flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-brand-100 flex items-center justify-center flex-shrink-0">
                <i data-lucide="file-text" class="w-5 h-5 text-brand-600"></i>
            </div>
            <div>
                <p class="text-2xl font-bold text-slate-900">@Model.TotalTemplates</p>
                <p class="text-xs text-slate-500">@L["Dashboard.SavedTemplates"]</p>
            </div>
        </div>

        <div class="card flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-emerald-100 flex items-center justify-center flex-shrink-0">
                <i data-lucide="git-branch" class="w-5 h-5 text-emerald-600"></i>
            </div>
            <div>
                <p class="text-2xl font-bold text-slate-900">@Model.TotalVersions</p>
                <p class="text-xs text-slate-500">@L["Dashboard.GeneratedVersions"]</p>
            </div>
        </div>

        <div class="card flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-violet-100 flex items-center justify-center flex-shrink-0">
                <i data-lucide="bot" class="w-5 h-5 text-violet-600"></i>
            </div>
            <div>
                <p class="text-2xl font-bold text-slate-900">@Model.TotalAgentProfiles</p>
                <p class="text-xs text-slate-500">@L["Dashboard.AgentProfiles"]</p>
            </div>
        </div>

        <div class="card flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-amber-100 flex items-center justify-center flex-shrink-0">
                <i data-lucide="layers" class="w-5 h-5 text-amber-600"></i>
            </div>
            <div>
                <p class="text-2xl font-bold text-slate-900">@Model.TotalTechnologies</p>
                <p class="text-xs text-slate-500">@L["Dashboard.RegisteredTechnologies"]</p>
            </div>
        </div>

    </div>

    <!-- Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Recent Templates -->
        <div class="lg:col-span-2 card">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-base font-semibold text-slate-900">@L["Dashboard.RecentTemplates"]</h2>
                <a asp-controller="Templates" asp-action="Index"
                   class="text-xs text-brand-600 hover:text-brand-700 font-medium">@L["Dashboard.ViewAll"]</a>
            </div>

            @if (!Model.RecentTemplates.Any())
            {
                <div class="text-center py-10">
                    <i data-lucide="inbox" class="w-10 h-10 text-slate-300 mx-auto mb-3"></i>
                    <p class="text-sm text-slate-500">@L["Dashboard.NoTemplates"]</p>
                    <a asp-controller="PromptGenerator" asp-action="Index"
                       class="btn btn-primary btn-sm mt-3">
                        @L["Dashboard.CreateFirstPrompt"]
                    </a>
                </div>
            }
            else
            {
                <ul class="divide-y divide-slate-100">
                    @foreach (var t in Model.RecentTemplates)
                    {
                        <li class="py-3 flex items-center justify-between group">
                            <div class="min-w-0">
                                <p class="text-sm font-medium text-slate-900 truncate">@t.Name</p>
                                <p class="text-xs text-slate-500 mt-0.5">
                                    v@(t.CurrentVersionNumber) · @t.UpdatedAt.ToString("dd/MM/yyyy HH:mm")
                                </p>
                            </div>
                            <a asp-controller="Templates" asp-action="Edit" asp-route-id="@t.Id"
                               class="btn btn-ghost btn-sm opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0"
                               title="@L["Dashboard.EditInWizard"]">
                                <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                @L["Common.Edit"]
                            </a>
                        </li>
                    }
                </ul>
            }
        </div>

        <!-- Right column -->
        <div class="space-y-6">

            <!-- Top Technologies -->
            <div class="card">
                <h2 class="text-sm font-semibold text-slate-900 mb-4">@L["Dashboard.TopTechnologies"]</h2>

                @if (!Model.TopTechnologies.Any())
                {
                    <div class="text-center py-6">
                        <i data-lucide="cpu" class="w-7 h-7 text-slate-300 mx-auto mb-2"></i>
                        <p class="text-xs text-slate-500">@L["Dashboard.NoData"]</p>
                    </div>
                }
                else
                {
                    var maxTech = Model.TopTechnologies.Max(t => t.Count);
                    <ul class="space-y-3">
                        @foreach (var tech in Model.TopTechnologies)
                        {
                            var pct = maxTech > 0 ? (tech.Count * 100 / maxTech) : 0;
                            <li>
                                <div class="flex items-center justify-between mb-1">
                                    <span class="text-xs font-medium text-slate-700 truncate">@tech.TechName</span>
                                    <span class="text-xs text-slate-400 ml-2 flex-shrink-0">@tech.Count</span>
                                </div>
                                <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                    <div class="h-full bg-brand-500 rounded-full" style="width: @pct%"></div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>

            <!-- Top Patterns -->
            <div class="card">
                <h2 class="text-sm font-semibold text-slate-900 mb-4">@L["Dashboard.TopPatterns"]</h2>

                @if (!Model.TopPatterns.Any())
                {
                    <div class="text-center py-6">
                        <i data-lucide="layout-template" class="w-7 h-7 text-slate-300 mx-auto mb-2"></i>
                        <p class="text-xs text-slate-500">@L["Dashboard.NoData"]</p>
                    </div>
                }
                else
                {
                    var maxPat = Model.TopPatterns.Max(p => p.Count);
                    <ul class="space-y-3">
                        @foreach (var pat in Model.TopPatterns)
                        {
                            var pct = maxPat > 0 ? (pat.Count * 100 / maxPat) : 0;
                            <li>
                                <div class="flex items-center justify-between mb-1">
                                    <span class="text-xs font-medium text-slate-700 truncate">@pat.TechName</span>
                                    <span class="text-xs text-slate-400 ml-2 flex-shrink-0">@pat.Count</span>
                                </div>
                                <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                    <div class="h-full bg-violet-500 rounded-full" style="width: @pct%"></div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>

        </div>

    </div>
</div>
