@{
    var pageTitle   = ViewData["Title"]?.ToString() ?? "Dashboard";
    var breadcrumb  = ViewData["Breadcrumb"] as string;
    var userName    = User.Identity?.IsAuthenticated == true
        ? (User.FindFirst("name")?.Value ?? User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Usuário")
        : null;
    var initial     = userName?.Length > 0 ? userName[0].ToString().ToUpper() : "?";
    var isLocalAdmin = User.FindFirst("local_admin")?.Value == "true";
    string RoleBadgeCss() => User.IsInRole("Admin")  ? "bg-red-500/20 text-red-200" :
                              User.IsInRole("Editor") ? "bg-blue-500/20 text-blue-200" : "";
    string RoleLabel()    => User.IsInRole("Admin")  ? "Admin" :
                              User.IsInRole("Editor") ? "Editor" : "";
}

<header class="bg-white border-b border-slate-200 px-6 py-3 flex items-center justify-between flex-shrink-0">

    @* Left: breadcrumb / title *@
    <div>
        <h1 class="text-lg font-semibold text-slate-900">@pageTitle</h1>
        @if (!string.IsNullOrEmpty(breadcrumb))
        {
            <p class="text-xs text-slate-500 mt-0.5">@breadcrumb</p>
        }
    </div>

    @* Right: actions + user *@
    <div class="flex items-center gap-3">
        <a asp-controller="PromptGenerator" asp-action="Index"
           class="btn btn-primary btn-sm">
            <i data-lucide="plus" class="w-3.5 h-3.5"></i>
            Novo Prompt
        </a>

        @if (userName is not null)
        {
            @* User avatar dropdown *@
            <div class="relative" x-data="{ open: false }">
                <button @@click="open = !open" @@click.outside="open = false"
                        class="flex items-center gap-2.5 px-2 py-1.5 rounded-lg hover:bg-slate-100 transition-colors">
                    @* Avatar: tenta foto do Graph, fallback para iniciais *@
                    <div class="relative w-8 h-8 flex-shrink-0">
                        @if (!isLocalAdmin)
                        {
                            <img src="/Account/Photo"
                                 alt="@userName"
                                 class="w-8 h-8 rounded-full object-cover"
                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                                 loading="lazy" />
                        }
                        <div class="w-8 h-8 rounded-full bg-indigo-600 items-center justify-center text-white text-xs font-bold uppercase @(isLocalAdmin ? "flex" : "absolute inset-0")"
                             @(isLocalAdmin ? "" : "style='display:none;'")>
                            @initial
                        </div>
                    </div>
                    <div class="hidden sm:block text-left leading-tight">
                        <p class="text-xs font-semibold text-slate-800 max-w-[120px] truncate">@userName</p>
                        @if (!string.IsNullOrEmpty(RoleLabel()))
                        {
                            <span class="text-[10px] px-1.5 py-0.5 rounded-full font-medium @RoleBadgeCss() bg-slate-100 text-slate-500">@RoleLabel()</span>
                        }
                    </div>
                    <i data-lucide="chevron-down" class="w-3.5 h-3.5 text-slate-400 hidden sm:block"></i>
                </button>

                @* Dropdown *@
                <div x-show="open" x-transition
                     class="absolute right-0 top-full mt-1 w-52 bg-white rounded-xl shadow-lg border border-slate-200 py-1 z-50">
                    <div class="px-4 py-2.5 border-b border-slate-100 flex items-center gap-3">
                    <div class="relative w-9 h-9 flex-shrink-0">
                            @if (!isLocalAdmin)
                            {
                                <img src="/Account/Photo"
                                     alt="@userName"
                                     class="w-9 h-9 rounded-full object-cover"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                                     loading="lazy" />
                            }
                            <div class="w-9 h-9 rounded-full bg-indigo-600 items-center justify-center text-white text-sm font-bold uppercase @(isLocalAdmin ? "flex" : "absolute inset-0")"
                                 @(isLocalAdmin ? "" : "style='display:none;'")>
                                @initial
                            </div>
                        </div>
                        <div class="min-w-0">
                            <p class="text-xs font-semibold text-slate-900 truncate">@userName</p>
                            @{
                                var email = User.FindFirst("preferred_username")?.Value ??
                                            User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
                            }
                            @if (!string.IsNullOrEmpty(email))
                            {
                                <p class="text-xs text-slate-400 truncate mt-0.5">@email</p>
                            }
                        </div>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Users" asp-action="Index"
                           class="flex items-center gap-2.5 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition-colors">
                            <i data-lucide="users" class="w-4 h-4 text-slate-400"></i>
                            Gerenciar Usuários
                        </a>
                    }
                    <a asp-controller="Settings" asp-action="Index"
                       class="flex items-center gap-2.5 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition-colors">
                        <i data-lucide="settings" class="w-4 h-4 text-slate-400"></i>
                        Configurações
                    </a>
                    <div class="border-t border-slate-100 mt-1 pt-1">
                        <a asp-controller="Account" asp-action="SignOut"
                           class="flex items-center gap-2.5 px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">
                            <i data-lucide="log-out" class="w-4 h-4"></i>
                            Sair
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login"
               class="btn btn-secondary btn-sm">
                <i data-lucide="log-in" class="w-3.5 h-3.5"></i>
                Entrar
            </a>
        }
    </div>

</header>

