@model Prompteer.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="w-16 h-16 rounded-2xl bg-red-100 flex items-center justify-center mb-6">
        <i data-lucide="alert-triangle" class="w-8 h-8 text-red-600"></i>
    </div>
    <h1 class="text-2xl font-bold text-slate-900 mb-2">@L["Shared.Error.Oops"]</h1>
    <p class="text-slate-500 max-w-md mb-6">
        @L["Shared.Error.Message"]
    </p>

    @if (Model?.ShowRequestId == true)
    {
        <p class="text-xs text-slate-400 bg-slate-100 rounded px-3 py-1 mb-6">
            @L["Shared.Error.RequestId"] <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">
        <i data-lucide="home" class="w-4 h-4"></i>
        @L["Shared.Error.BackToDashboard"]
    </a>
</div>
