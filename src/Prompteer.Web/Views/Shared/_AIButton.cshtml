@* Parâmetros: fieldId (id do input/textarea), fieldType (chave do prompt), contextFields (dict JS inline) *@
@inject Prompteer.Application.Services.IAIService AiService
@{
    var fieldId      = (string)ViewData["fieldId"]!;
    var fieldType    = (string)ViewData["fieldType"]!;
    var contextJs    = (string)(ViewData["contextJs"] ?? "{}");
    var btnId        = $"btnAI_{fieldId}";
    var aiConfigured = await AiService.IsConfiguredAsync();
}
@if (!aiConfigured) { return; }
<button type="button" id="@btnId"
        onclick="aiGenerate('@fieldId','@fieldType',@Html.Raw(contextJs),this)"
        class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium
               bg-violet-50 text-violet-700 border border-violet-200
               hover:bg-violet-100 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        title="@L["Common.GenerateWithAI"]">
    <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
    @L["Common.GenerateWithAI"]
</button>
