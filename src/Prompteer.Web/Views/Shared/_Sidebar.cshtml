@inject Prompteer.Application.Services.IAppSettingService AppSettings
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var logoUrl = await AppSettings.GetAsync("App:LogoUrl");
}

<!-- Mobile backdrop -->
<div x-show="sidebarOpen"
     x-cloak
     @@click="sidebarOpen = false"
     class="fixed inset-0 z-30 bg-black/50 lg:hidden"
     x-transition:enter="transition-opacity duration-200"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition-opacity duration-200"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0">
</div>

<aside :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'"
       class="fixed inset-y-0 left-0 z-40 w-64 flex-shrink-0 bg-slate-900 flex flex-col h-full transition-transform duration-200 ease-in-out lg:relative lg:translate-x-0 lg:z-auto">

    <!-- Logo -->
    <div class="flex items-center justify-center gap-3 px-5 py-5 border-b border-slate-700/50">
        @if (!string.IsNullOrWhiteSpace(logoUrl))
        {
            <img src="@logoUrl" alt="Logo" class="h-8 max-w-[140px] object-contain" />
        }
        else
        {
            <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center flex-shrink-0">
                <i data-lucide="zap" class="w-4 h-4 text-white"></i>
            </div>
            <span class="text-white font-semibold text-lg tracking-tight">Prompteer</span>
        }
    </div>

    <!-- Navigation -->
    <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">

        <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider px-3 mb-2">@L["Sidebar.Main"]</p>

        <a asp-controller="Dashboard" asp-action="Index"
           class="sidebar-link @(controller == "Dashboard" ? "sidebar-link-active" : "")">
            <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
            @L["Sidebar.Dashboard"]
        </a>

        <a asp-controller="PromptGenerator" asp-action="Index"
           class="sidebar-link @(controller == "PromptGenerator" ? "sidebar-link-active" : "")">
            <i data-lucide="wand-2" class="w-4 h-4"></i>
            @L["Sidebar.PromptGenerator"]
        </a>

        <a asp-controller="Templates" asp-action="Index"
           class="sidebar-link @(controller == "Templates" ? "sidebar-link-active" : "")">
            <i data-lucide="file-text" class="w-4 h-4"></i>
            @L["Sidebar.Templates"]
        </a>

        <div class="pt-4">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider px-3 mb-2">@L["Sidebar.Registrations"]</p>

            <a asp-controller="AgentProfiles" asp-action="Index"
               class="sidebar-link @(controller == "AgentProfiles" ? "sidebar-link-active" : "")">
                <i data-lucide="bot" class="w-4 h-4"></i>
                @L["Sidebar.AgentProfiles"]
            </a>

            <a asp-controller="Technologies" asp-action="Index"
               class="sidebar-link @(controller == "Technologies" ? "sidebar-link-active" : "")">
                <i data-lucide="cpu" class="w-4 h-4"></i>
                @L["Sidebar.Technologies"]
            </a>

            <a asp-controller="ArchitecturalPatterns" asp-action="Index"
               class="sidebar-link @(controller == "ArchitecturalPatterns" ? "sidebar-link-active" : "")">
                <i data-lucide="layers" class="w-4 h-4"></i>
                @L["Sidebar.ArchitecturalPatterns"]
            </a>

            <a asp-controller="BacklogTools" asp-action="Index"
               class="sidebar-link @(controller == "BacklogTools" ? "sidebar-link-active" : "")">
                <i data-lucide="clipboard-list" class="w-4 h-4"></i>
                @L["Sidebar.BacklogTools"]
            </a>
        </div>

    </nav>

    <!-- Footer -->
    <div class="px-3 py-4 border-t border-slate-700/50 space-y-1">
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Users" asp-action="Index"
               class="sidebar-link @(controller == "Users" ? "sidebar-link-active" : "")">
                <i data-lucide="users" class="w-4 h-4"></i>
                @L["Sidebar.Users"]
            </a>
            <a asp-controller="Settings" asp-action="Index"
               class="sidebar-link @(controller == "Settings" ? "sidebar-link-active" : "")">
                <i data-lucide="settings" class="w-4 h-4"></i>
                @L["Sidebar.Settings"]
            </a>
        }
        <p class="text-xs text-slate-500 px-3 pt-1">.NET 10 · EF Core · PostgreSQL</p>
    </div>

</aside>
