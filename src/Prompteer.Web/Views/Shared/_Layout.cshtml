<!DOCTYPE html>
<html lang="pt-BR" x-data="{ sidebarOpen: true }">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — Prompteer" : "Prompteer")</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <!-- Tom Select -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.min.css" />
    <!-- Highlight.js -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/styles/github.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-slate-50 text-slate-800 antialiased">

<!-- ── Layout Shell ───────────────────────────────────────────────────── -->
<div class="flex h-screen overflow-hidden">

    <!-- Sidebar -->
    @await Html.PartialAsync("_Sidebar")

    <!-- Main Column -->
    <div class="flex flex-col flex-1 overflow-hidden">

        <!-- Top Navbar -->
        @await Html.PartialAsync("_Navbar")

        <!-- Page Content -->
        <main class="flex-1 overflow-y-auto p-6">

            <!-- Toasts (TempData) -->
            @await Html.PartialAsync("_Toast")

            @RenderBody()

        </main>
    </div>
</div>

<!-- Alpine.js -->
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.3/dist/cdn.min.js"></script>
<!-- Lucide Icons -->
<script src="https://unpkg.com/lucide@0.441.0/dist/umd/lucide.min.js"></script>
<!-- Tom Select -->
<script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
<!-- SortableJS -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.3/Sortable.min.js"></script>
<!-- Highlight.js -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.10.0/highlight.min.js"></script>
<!-- marked.js -->
<script src="https://cdn.jsdelivr.net/npm/marked@12.0.0/marked.min.js"></script>

<script>
    // Inicializa Lucide icons
    document.addEventListener('DOMContentLoaded', function () {
        lucide.createIcons();
    });

    // ── Geração com IA ───────────────────────────────────────────────────────
    async function aiGenerate(fieldId, fieldType, context, btn) {
        const field = document.getElementById(fieldId);
        if (!field) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        if (!token) { alert('Token CSRF não encontrado.'); return; }

        const originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<svg class="animate-spin w-3.5 h-3.5 inline mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>Gerando...';

        try {
            const resp = await fetch('/api/ai/generate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({ fieldType, context })
            });
            const data = await resp.json();
            if (data.success) {
                field.value = data.text;
                field.dispatchEvent(new Event('input'));
            } else {
                alert('IA: ' + (data.error ?? 'Erro desconhecido.'));
            }
        } catch (e) {
            alert('Falha na comunicação com o servidor.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
            lucide.createIcons();
        }
    }
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
