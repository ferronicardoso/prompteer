@{
    var success = TempData["Success"]?.ToString();
    var error   = TempData["Error"]?.ToString();
    var warning = TempData["Warning"]?.ToString();
    var info    = TempData["Info"]?.ToString();
}

@if (success != null || error != null || warning != null || info != null)
{
    var toastList = new System.Text.Json.Nodes.JsonArray();
    if (success != null) toastList.Add(System.Text.Json.Nodes.JsonNode.Parse($"{{\"type\":\"success\",\"msg\":{System.Text.Json.JsonSerializer.Serialize(success)}}}"));
    if (error   != null) toastList.Add(System.Text.Json.Nodes.JsonNode.Parse($"{{\"type\":\"error\",\"msg\":{System.Text.Json.JsonSerializer.Serialize(error)}}}"));
    if (warning != null) toastList.Add(System.Text.Json.Nodes.JsonNode.Parse($"{{\"type\":\"warning\",\"msg\":{System.Text.Json.JsonSerializer.Serialize(warning)}}}"));
    if (info    != null) toastList.Add(System.Text.Json.Nodes.JsonNode.Parse($"{{\"type\":\"info\",\"msg\":{System.Text.Json.JsonSerializer.Serialize(info)}}}"));

    <script>window.__pendingToasts = @Html.Raw(toastList.ToJsonString());</script>

    <div id="toast-container"
         class="fixed top-4 right-4 z-50 flex flex-col gap-2 min-w-[300px] max-w-sm"
         x-data="{ toasts: [] }"
         x-init="toasts = window.__pendingToasts; toasts.forEach((t,i) => setTimeout(() => toasts.splice(i,1), 4000))">

        <template x-for="(toast, index) in toasts" :key="index">
            <div x-show="true"
                 x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-x-4"
                 x-transition:enter-end="opacity-100 translate-x-0"
                 x-transition:leave="transition ease-in duration-200"
                 x-transition:leave-start="opacity-100 translate-x-0"
                 x-transition:leave-end="opacity-0 translate-x-4"
                 :class="{
                    'bg-emerald-50 border-emerald-400 text-emerald-800': toast.type === 'success',
                    'bg-red-50 border-red-400 text-red-800': toast.type === 'error',
                    'bg-amber-50 border-amber-400 text-amber-800': toast.type === 'warning',
                    'bg-blue-50 border-blue-400 text-blue-800': toast.type === 'info'
                 }"
                 class="flex items-start gap-3 p-4 rounded-lg border shadow-lg">

                <i :data-lucide="toast.type === 'success' ? 'check-circle' : toast.type === 'error' ? 'x-circle' : toast.type === 'warning' ? 'alert-triangle' : 'info'"
                   class="w-5 h-5 flex-shrink-0 mt-0.5"></i>

                <p class="text-sm font-medium flex-1" x-text="toast.msg"></p>

                <button @@click="toasts.splice(index, 1)"
                        class="flex-shrink-0 opacity-60 hover:opacity-100 transition-opacity">
                    <i data-lucide="x" class="w-4 h-4"></i>
                </button>
            </div>
        </template>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => lucide.createIcons());
    </script>
}
