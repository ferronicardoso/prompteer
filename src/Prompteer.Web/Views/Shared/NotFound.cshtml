@{
    ViewData["Title"] = "Page not found";
    Layout = "_Layout";
}

<div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <p class="text-8xl font-black text-slate-200 mb-4">404</p>
    <div class="w-16 h-16 rounded-2xl bg-slate-100 flex items-center justify-center mb-6">
        <i data-lucide="search-x" class="w-8 h-8 text-slate-500"></i>
    </div>
    <h1 class="text-2xl font-bold text-slate-900 mb-2">@L["Shared.NotFound.Title"]</h1>
    <p class="text-slate-500 max-w-md mb-6">
        @L["Shared.NotFound.Message"]
    </p>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">
        <i data-lucide="home" class="w-4 h-4"></i>
        @L["Shared.NotFound.BackToDashboard"]
    </a>
</div>
