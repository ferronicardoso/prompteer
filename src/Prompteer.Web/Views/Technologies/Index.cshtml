@using Prompteer.Application.DTOs
@using Prompteer.Domain.Enums
@model PagedResult<TechnologyDto>
@{
    ViewData["Title"] = "Tecnologias";
    var search = ViewData["Search"]?.ToString() ?? "";
    var currentCategory = ViewData["Category"] as TechCategory?;
    var currentEcosystem = ViewData["Ecosystem"] as TechEcosystem?;
}

<div class="space-y-4">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-xl font-semibold text-slate-900">Tecnologias</h1>
            <p class="text-sm text-slate-500 mt-0.5">Gerencie as tecnologias disponíveis para uso nos prompts</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i data-lucide="plus" class="w-4 h-4"></i>
            Nova Tecnologia
        </a>
    </div>

    <!-- Search & Filters -->
    <form method="get" asp-action="Index" class="flex flex-wrap gap-2">
        <div class="relative flex-1 min-w-48">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
            <input type="text" name="search" value="@search"
                   placeholder="Buscar por nome..."
                   class="form-input pl-9 w-full" />
        </div>
        <select name="category" class="form-select">
            <option value="">Todas as categorias</option>
            @foreach (var item in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.CategoryItems)
            {
                <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">@item.Text</option>
            }
        </select>
        <select name="ecosystem" class="form-select">
            <option value="">Todos os ecossistemas</option>
            @foreach (var item in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.EcosystemItems)
            {
                <option value="@item.Value" selected="@(item.Selected ? "selected" : null)">@item.Text</option>
            }
        </select>
        <button type="submit" class="btn btn-secondary">Filtrar</button>
        @if (!string.IsNullOrEmpty(search) || currentCategory.HasValue || currentEcosystem.HasValue)
        {
            <a asp-action="Index" class="btn btn-ghost">Limpar</a>
        }
    </form>

    <!-- Table -->
    <div class="card p-0 overflow-hidden">
        @if (!Model.Items.Any())
        {
            <div class="text-center py-16">
                <i data-lucide="cpu" class="w-10 h-10 text-slate-300 mx-auto mb-3"></i>
                <p class="text-sm text-slate-500">Nenhuma tecnologia encontrada.</p>
                <a asp-action="Create" class="btn btn-primary btn-sm mt-3">Criar primeira tecnologia</a>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-200 bg-slate-50">
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Nome</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Categoria</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Ecossistema</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Versão</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Criado em</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model.Items)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-4 py-3">
                                <div>
                                    <div class="flex items-center gap-2">
                                        <p class="font-medium text-slate-900">@item.Name</p>
                                        @if (item.IsSystemDefault)
                                        {
                                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600">
                                                <i data-lucide="lock" class="w-3 h-3"></i> Padrão
                                            </span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.ShortDescription))
                                    {
                                        <p class="text-xs text-slate-500 mt-0.5 truncate max-w-xs">@item.ShortDescription</p>
                                    }
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                @{
                                    var catCss = item.Category switch
                                    {
                                        TechCategory.Framework     => "bg-blue-100 text-blue-700",
                                        TechCategory.Database      => "bg-emerald-100 text-emerald-700",
                                        TechCategory.ORM           => "bg-teal-100 text-teal-700",
                                        TechCategory.Frontend      => "bg-violet-100 text-violet-700",
                                        TechCategory.Auth          => "bg-orange-100 text-orange-700",
                                        TechCategory.Messaging     => "bg-pink-100 text-pink-700",
                                        TechCategory.Cache         => "bg-cyan-100 text-cyan-700",
                                        TechCategory.Observability => "bg-amber-100 text-amber-700",
                                        TechCategory.DevOps        => "bg-slate-100 text-slate-700",
                                        TechCategory.Testing               => "bg-green-100 text-green-700",
                                        TechCategory.ArtificialIntelligence => "bg-fuchsia-100 text-fuchsia-700",
                                        _                          => "bg-gray-100 text-gray-700"
                                    };
                                }
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium @catCss">@item.CategoryDisplay</span>
                            </td>
                            <td class="px-4 py-3">
                                @{
                                    var ecoCss = item.Ecosystem switch
                                    {
                                        TechEcosystem.DotNet   => "bg-purple-100 text-purple-700",
                                        TechEcosystem.Node     => "bg-lime-100 text-lime-700",
                                        TechEcosystem.Python   => "bg-yellow-100 text-yellow-700",
                                        TechEcosystem.Java     => "bg-orange-100 text-orange-700",
                                        TechEcosystem.Agnostic => "bg-gray-100 text-gray-600",
                                        _                      => "bg-gray-100 text-gray-600"
                                    };
                                }
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium @ecoCss">@item.EcosystemDisplay</span>
                            </td>
                            <td class="px-4 py-3 text-slate-500">@(item.Version ?? "—")</td>
                            <td class="px-4 py-3 text-slate-500">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-end gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-ghost btn-sm">
                                        <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                        Editar
                                    </a>
                                    @if (!item.IsSystemDefault)
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-ghost btn-sm text-red-600 hover:text-red-700">
                                            <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                                            Excluir
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @await Html.PartialAsync("_Pagination", new PagedResult<dynamic>
            {
                TotalCount = Model.TotalCount,
                Page = Model.Page,
                PageSize = Model.PageSize
            })
        }
    </div>
</div>
