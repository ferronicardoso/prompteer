@using Prompteer.Application.DTOs
@model BacklogToolFormDto
@{
    ViewData["Title"] = "Nova Ferramenta de Backlog";
}

<div class="max-w-2xl">
    <!-- Header -->
    <div class="mb-6">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-2">
            <a asp-action="Index" class="hover:text-slate-700">Ferramentas de Backlog</a>
            <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
            <span class="text-slate-900">Nova Ferramenta</span>
        </nav>
        <h1 class="text-xl font-semibold text-slate-900">Nova Ferramenta de Backlog</h1>
    </div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="card space-y-5">
            <div asp-validation-summary="ModelOnly" class="rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-700"></div>

            <!-- Name -->
            <div>
                <label asp-for="Name" class="block text-sm font-medium text-slate-700 mb-1">Nome <span class="text-red-500">*</span></label>
                <input asp-for="Name" class="form-input w-full" placeholder="Ex: Jira, Linear, Trello" />
                <span asp-validation-for="Name" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            <!-- Default Instructions -->
            <div>
                <div class="flex items-center justify-between mb-1">
                    <label asp-for="DefaultInstructions" class="text-sm font-medium text-slate-700">Instruções Padrão <span class="text-red-500">*</span></label>
                    <button type="button" onclick="aiGenerate('DefaultInstructions','BacklogInstructions',{name:document.getElementById('Name').value},this)" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-violet-50 text-violet-700 border border-violet-200 hover:bg-violet-100 transition-colors"><i data-lucide="sparkles" class="w-3.5 h-3.5"></i> Gerar com IA</button>
                </div>
                <textarea asp-for="DefaultInstructions" rows="6" class="form-textarea w-full" placeholder="Descreva as instruções padrão para uso desta ferramenta nos prompts..."></textarea>
                <span asp-validation-for="DefaultInstructions" class="text-xs text-red-600 mt-1 block"></span>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
                <button type="submit" class="btn btn-primary">
                    <i data-lucide="save" class="w-4 h-4"></i>
                    Salvar
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
