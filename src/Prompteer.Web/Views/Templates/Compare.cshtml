@using Prompteer.Web.Models
@model CompareViewModel
@{
    ViewData["Title"] = $"{L["Templates.Details.Compare"]} — {Model.Template.Name}";
}

<div class="space-y-4">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-slate-500">
        <a asp-action="Index" class="hover:text-brand-600 transition-colors">Templates</a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
        <a asp-action="Details" asp-route-id="@Model.Template.Id" class="hover:text-brand-600 transition-colors">@Model.Template.Name</a>
        <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
        <span>@L["Templates.Compare.Title"] v@(Model.Version1.VersionNumber) ↔ v@(Model.Version2.VersionNumber)</span>
    </div>

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-xl font-semibold text-slate-900">@L["Templates.Compare.Title"] @Model.Template.Name</h1>
            <p class="text-sm text-slate-500 mt-0.5">
                @string.Format(L["Templates.Compare.DifferencesBetween"].Value, Model.Version1.VersionNumber, Model.Version2.VersionNumber)
            </p>
        </div>
        <a asp-action="Versions" asp-route-id="@Model.Template.Id" class="btn btn-secondary btn-sm">
            <i data-lucide="arrow-left" class="w-4 h-4"></i>
            @L["Templates.Compare.Back"]
        </a>
    </div>

    <!-- Side-by-side diff -->
    <div class="grid grid-cols-2 gap-4">
        <!-- Version 1 -->
        <div class="card p-0 overflow-hidden">
            <div class="px-4 py-3 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
                <div>
                    <span class="font-semibold text-slate-700">v@(Model.Version1.VersionNumber)</span>
                    <span class="ml-2 text-xs text-slate-400">@Model.Version1.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700">
                    <i data-lucide="minus" class="w-3 h-3 mr-1"></i> @L["Templates.Compare.Previous"]
                </span>
            </div>
            <div id="diff-left" class="p-4 overflow-x-auto text-sm font-mono leading-relaxed whitespace-pre-wrap bg-white"></div>
        </div>

        <!-- Version 2 -->
        <div class="card p-0 overflow-hidden">
            <div class="px-4 py-3 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
                <div>
                    <span class="font-semibold text-slate-700">v@(Model.Version2.VersionNumber)</span>
                    <span class="ml-2 text-xs text-slate-400">@Model.Version2.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">
                    <i data-lucide="plus" class="w-3 h-3 mr-1"></i> @L["Templates.Compare.Newer"]
                </span>
            </div>
            <div id="diff-right" class="p-4 overflow-x-auto text-sm font-mono leading-relaxed whitespace-pre-wrap bg-white"></div>
        </div>
    </div>

    <!-- Legend -->
    <div class="flex items-center gap-4 text-xs text-slate-500">
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded bg-red-100 border border-red-300"></span> @L["Templates.Compare.RemovedLine"]</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded bg-green-100 border border-green-300"></span> @L["Templates.Compare.AddedLine"]</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded bg-white border border-slate-200"></span> @L["Templates.Compare.UnchangedLine"]</span>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const text1 = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Version1.GeneratedPrompt));
            const text2 = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Version2.GeneratedPrompt));

            const lines1 = text1.split('\n');
            const lines2 = text2.split('\n');
            const set1 = new Set(lines1);
            const set2 = new Set(lines2);

            function renderDiff(container, lines, otherSet, removedStyle, unchangedStyle) {
                container.innerHTML = '';
                lines.forEach(line => {
                    const span = document.createElement('div');
                    span.style.padding = '0 2px';
                    span.style.borderRadius = '2px';
                    span.style.marginBottom = '1px';
                    if (!otherSet.has(line)) {
                        span.style.backgroundColor = removedStyle;
                    } else {
                        span.style.backgroundColor = unchangedStyle;
                    }
                    span.textContent = line || '\u00A0';
                    container.appendChild(span);
                });
            }

            document.addEventListener('DOMContentLoaded', function () {
                renderDiff(document.getElementById('diff-left'), lines1, set2, '#fee2e2', 'transparent');
                renderDiff(document.getElementById('diff-right'), lines2, set1, '#dcfce7', 'transparent');
            });
        })();
    </script>
}
