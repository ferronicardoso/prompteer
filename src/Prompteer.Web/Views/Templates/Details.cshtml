@using Prompteer.Web.Models
@model TemplateDetailsViewModel
@{
    ViewData["Title"] = Model.Template.Name;
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-start justify-between">
        <div>
            <div class="flex items-center gap-2 text-sm text-slate-500 mb-1">
                <a asp-action="Index" class="hover:text-brand-600 transition-colors">Templates</a>
                <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
                <span>@Model.Template.Name</span>
            </div>
            <h1 class="text-xl font-semibold text-slate-900">@Model.Template.Name</h1>
            @if (!string.IsNullOrEmpty(Model.Template.Description))
            {
                <p class="text-sm text-slate-500 mt-1">@Model.Template.Description</p>
            }
            <div class="flex items-center gap-4 mt-2 text-xs text-slate-400">
                <span><i data-lucide="calendar" class="w-3.5 h-3.5 inline-block mr-1"></i>@L["Templates.Details.CreatedOn"] @Model.Template.CreatedAt.ToString("dd/MM/yyyy")</span>
                <span><i data-lucide="clock" class="w-3.5 h-3.5 inline-block mr-1"></i>@L["Templates.Details.UpdatedOn"] @Model.Template.UpdatedAt.ToString("dd/MM/yyyy")</span>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600">
                    v@(Model.Template.CurrentVersionNumber)
                </span>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <a asp-action="Export" asp-route-id="@Model.Template.Id" class="btn btn-secondary btn-sm">
                <i data-lucide="download" class="w-4 h-4"></i>
                @L["Templates.Details.Download"]
            </a>
            <form method="post" asp-action="SetVisibility" asp-route-id="@Model.Template.Id" class="inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="isPublic" value="@(!Model.Template.IsPublic ? "true" : "false")" />
                <button type="submit"
                        class="btn btn-sm @(Model.Template.IsPublic ? "btn-secondary" : "btn-ghost border border-slate-300 text-slate-600 hover:border-brand-400 hover:text-brand-700 hover:bg-brand-50")">
                    <i data-lucide="@(Model.Template.IsPublic ? "lock" : "globe")" class="w-4 h-4"></i>
                    @(Model.Template.IsPublic ? L["Templates.Details.MakePrivate"] : L["Templates.Details.MakePublic"])
                </button>
            </form>
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium @(Model.Template.IsPublic ? "bg-green-100 text-green-700" : "bg-slate-100 text-slate-600")">
                <i data-lucide="@(Model.Template.IsPublic ? "globe" : "lock")" class="w-3 h-3"></i>
                @(Model.Template.IsPublic ? L["Templates.Details.VisibilityPublic"] : L["Templates.Details.VisibilityPrivate"])
            </span>
            <a asp-action="Versions" asp-route-id="@Model.Template.Id" class="btn btn-secondary btn-sm">
                <i data-lucide="history" class="w-4 h-4"></i>
                @L["Templates.Details.Versions"]
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Template.Id" class="btn btn-primary btn-sm">
                <i data-lucide="pencil" class="w-4 h-4"></i>
                @L["Templates.Details.Edit"]
            </a>
        </div>
    </div>

    <!-- Latest Prompt -->
    @if (!string.IsNullOrEmpty(Model.LatestPrompt))
    {
        <div class="card">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-sm font-semibold text-slate-700">@L["Templates.Details.CurrentPrompt"] (v@(Model.Template.CurrentVersionNumber))</h2>
                <button type="button"
                        x-data="{ copied: false }"
                        @@click="navigator.clipboard.writeText(window.__rawPromptDetails); copied = true; setTimeout(() => copied = false, 2000)"
                        class="btn btn-ghost btn-sm">
                    <i data-lucide="copy" class="w-3.5 h-3.5"></i>
                    <span x-text="copied ? '@L["Templates.Details.Copied"]' : '@L["Templates.Details.Copy"]'">@L["Templates.Details.Copy"]</span>
                </button>
            </div>
            <div class="overflow-auto max-h-[40rem] rounded-lg border border-slate-200 bg-white p-5">
                <div id="promptRenderedDetails" class="markdown-body"></div>
            </div>
        </div>
    }

    <!-- Version History -->
    <div class="card p-0 overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-200 bg-slate-50">
            <h2 class="text-sm font-semibold text-slate-700">@L["Templates.Details.VersionHistory"]</h2>
        </div>
        @if (!Model.Versions.Any())
        {
            <div class="text-center py-8">
                <p class="text-sm text-slate-500">@L["Templates.Details.NoVersions"]</p>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-200">
                        <th class="text-left px-4 py-3 font-medium text-slate-600">@L["Common.Version"]</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">@L["Common.Created"]</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var v in Model.Versions.OrderByDescending(x => x.VersionNumber))
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-4 py-3">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600">
                                    v@(v.VersionNumber)
                                </span>
                                @if (v.VersionNumber == Model.Template.CurrentVersionNumber)
                                {
                                    <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">@L["Templates.Details.Current"]</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-slate-500">@v.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-action="Version"
                                       asp-route-templateId="@Model.Template.Id"
                                       asp-route-versionNumber="@v.VersionNumber"
                                       class="btn btn-ghost btn-sm">
                                        <i data-lucide="eye" class="w-3.5 h-3.5"></i>
                                        @L["Common.View"]
                                    </a>
                                    @{
                                        var others = Model.Versions.Where(x => x.VersionNumber != v.VersionNumber).OrderByDescending(x => x.VersionNumber).FirstOrDefault();
                                    }
                                    @if (others != null)
                                    {
                                        <a asp-action="Compare"
                                           asp-route-templateId="@Model.Template.Id"
                                           asp-route-v1="@Math.Min(v.VersionNumber, others.VersionNumber)"
                                           asp-route-v2="@Math.Max(v.VersionNumber, others.VersionNumber)"
                                           class="btn btn-ghost btn-sm">
                                            <i data-lucide="git-compare" class="w-3.5 h-3.5"></i>
                                            @L["Templates.Details.Compare"]
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const raw = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LatestPrompt ?? ""));
            window.__rawPromptDetails = raw;
            document.getElementById('promptRenderedDetails').innerHTML = marked.parse(raw);
        });
    </script>
}
