@using Prompteer.Application.DTOs
@using System.Text.Json
@model PagedResult<PromptTemplateSummaryDto>
@{
    ViewData["Title"] = "Prompt Templates";
    var search = ViewData["Search"]?.ToString() ?? "";
    ImportResultDto? importResult = null;
    if (TempData["ImportResult"] is string ir)
        importResult = JsonSerializer.Deserialize<ImportResultDto>(ir, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
}

<div class="space-y-4">
    @* Header *@
    <div class="flex items-center justify-between flex-wrap gap-3">
        <div>
            <h1 class="text-xl font-semibold text-slate-900">@L["Templates.Title"]</h1>
            <p class="text-sm text-slate-500 mt-0.5">@L["Templates.Subtitle"]</p>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
            <a asp-action="Import"
               class="btn btn-secondary">
                <i data-lucide="upload" class="w-4 h-4"></i>
                @L["Templates.Import"]
            </a>
            <a asp-action="ExportAll"
               class="btn btn-secondary"
               title="@L["Templates.ExportAllTitle"]">
                <i data-lucide="download" class="w-4 h-4"></i>
                @L["Templates.ExportAll"]
            </a>
            <a asp-controller="PromptGenerator" asp-action="Index" class="btn btn-primary">
                <i data-lucide="plus" class="w-4 h-4"></i>
                @L["Templates.NewTemplate"]
            </a>
        </div>
    </div>

    @* Import result banner *@
    @if (importResult is not null)
    {
        @if (importResult.Imported > 0)
        {
            <div class="flex items-start gap-3 p-4 rounded-xl bg-green-50 border border-green-200 text-green-800 text-sm">
                <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0 mt-0.5 text-green-600"></i>
                <div>
                    <p class="font-semibold">
                        @importResult.Imported @L["Templates.ImportResult.Success"]
                        @if (importResult.Skipped > 0) { <text>· @importResult.Skipped @L["Templates.ImportResult.Skipped"]</text> }
                    </p>
                    @if (importResult.ImportedNames.Any())
                    {
                        <p class="mt-1 text-green-700">@string.Join(", ", importResult.ImportedNames)</p>
                    }
                </div>
            </div>
        }
        @if (importResult.Errors.Any())
        {
            <div class="flex items-start gap-3 p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm">
                <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0 mt-0.5"></i>
                <div>
                    <p class="font-semibold">@L["Templates.ImportResult.Errors"]</p>
                    <ul class="list-disc list-inside mt-1 space-y-0.5">
                        @foreach (var e in importResult.Errors)
                        {
                            <li>@e</li>
                        }
                    </ul>
                </div>
            </div>
        }
        @if (importResult.Imported == 0 && importResult.Skipped > 0 && !importResult.Errors.Any())
        {
            <div class="flex items-center gap-3 p-4 rounded-xl bg-amber-50 border border-amber-200 text-amber-700 text-sm">
                <i data-lucide="alert-triangle" class="w-5 h-5 flex-shrink-0"></i>
                <p>@importResult.Skipped @L["Templates.ImportResult.AllSkipped"]</p>
            </div>
        }
    }

    <!-- Search -->
    <form method="get" asp-action="Index" class="flex gap-2">
        <div class="relative flex-1 max-w-sm">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
            <input type="text" name="search" value="@search"
                   placeholder="@L["Templates.SearchPlaceholder"]"
                   class="form-input pl-9 w-full" />
        </div>
        <button type="submit" class="btn btn-secondary">@L["Common.Filter"]</button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a asp-action="Index" class="btn btn-ghost">@L["Common.Clear"]</a>
        }
    </form>

    <!-- Table -->
    <div class="card p-0 overflow-hidden">
        @if (!Model.Items.Any())
        {
            <div class="text-center py-16">
                <i data-lucide="file-text" class="w-10 h-10 text-slate-300 mx-auto mb-3"></i>
                <p class="text-sm text-slate-500">@L["Templates.NoResults"]</p>
                <a asp-controller="PromptGenerator" asp-action="Index" class="btn btn-primary btn-sm mt-3">@L["Templates.CreateFirst"]</a>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-200 bg-slate-50">
                        <th class="text-left px-4 py-3 font-medium text-slate-600">@L["Templates.Name"]</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">@L["Templates.Description"]</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">@L["Common.Version"]</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">@L["Templates.Technologies"]</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">@L["Common.Updated"]</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model.Items)
                    {
                        <tr class="hover:bg-slate-50 transition-colors" x-data="{ cloneOpen: false, deleteOpen: false }">
                            <td class="px-4 py-3">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="font-medium text-slate-900 hover:text-brand-600 transition-colors">@item.Name</a>
                            </td>
                            <td class="px-4 py-3 text-slate-500 max-w-xs truncate">@(item.Description ?? "—")</td>
                            <td class="px-4 py-3">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600">
                                    v@(item.CurrentVersionNumber)
                                </span>
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var tech in item.TechnologyNames.Take(3))
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-700">@tech</span>
                                    }
                                    @if (item.TechnologyNames.Count > 3)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-500">+@(item.TechnologyNames.Count - 3)</span>
                                    }
                                </div>
                            </td>
                            <td class="px-4 py-3 text-slate-500">@item.UpdatedAt.ToString((string)ViewData["DateFormat"]!)</td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-end gap-1">
                                    <!-- Edit -->
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-ghost btn-sm" title="@L["Dashboard.EditInWizard"]">
                                        <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                        @L["Common.Edit"]
                                    </a>

                                    <!-- Clone trigger -->
                                    <button type="button" @@click="cloneOpen = true" class="btn btn-ghost btn-sm" title="@L["Templates.CloneTemplate"]">
                                        <i data-lucide="copy" class="w-3.5 h-3.5"></i>
                                        @L["Common.Clone"]
                                    </button>

                                    <!-- Delete trigger -->
                                    <button type="button" @@click="deleteOpen = true" class="btn btn-ghost btn-sm text-red-600 hover:text-red-700" title="@L["Templates.Delete.Title"]">
                                        <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                                        @L["Common.Delete"]
                                    </button>
                                </div>

                                <!-- Clone modal -->
                                <div x-show="cloneOpen" x-cloak
                                     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                                     @@keydown.escape.window="cloneOpen = false">
                                    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-sm" @@click.stop>
                                        <h3 class="text-base font-semibold text-slate-900 mb-4">@L["Templates.CloneTemplate"]</h3>
                                        <form asp-action="Clone" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <label class="block text-sm font-medium text-slate-700 mb-1">@L["Templates.CloneName"]</label>
                                            <input type="text" name="newName" value="@(item.Name) @L["Templates.CloneSuffix"].Value"
                                                   class="form-input w-full mb-4" required />
                                            <div class="flex justify-end gap-2">
                                                <button type="button" @@click="cloneOpen = false" class="btn btn-ghost">@L["Common.Cancel"]</button>
                                                <button type="submit" class="btn btn-primary">@L["Common.Clone"]</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                <!-- Delete confirm -->
                                <div x-show="deleteOpen" x-cloak
                                     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                                     @@keydown.escape.window="deleteOpen = false">
                                    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-sm" @@click.stop>
                                        <h3 class="text-base font-semibold text-slate-900 mb-2">@L["Templates.Delete.Title"]</h3>
                                        <p class="text-sm text-slate-500 mb-4">
                                            @string.Format(L["Templates.Delete.Warning"], item.Name)
                                        </p>
                                        <div class="flex justify-end gap-2">
                                            <button type="button" @@click="deleteOpen = false" class="btn btn-ghost">@L["Common.Cancel"]</button>
                                            <form asp-action="Delete" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-danger">@L["Common.Delete"]</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @await Html.PartialAsync("_Pagination", new PagedResult<dynamic>
            {
                TotalCount = Model.TotalCount,
                Page = Model.Page,
                PageSize = Model.PageSize
            })
        }
    </div>
</div>
