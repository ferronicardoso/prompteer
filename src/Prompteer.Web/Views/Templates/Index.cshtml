@using Prompteer.Application.DTOs
@model PagedResult<PromptTemplateSummaryDto>
@{
    ViewData["Title"] = "Templates de Prompt";
    var search = ViewData["Search"]?.ToString() ?? "";
}

<div class="space-y-4">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-xl font-semibold text-slate-900">Templates de Prompt</h1>
            <p class="text-sm text-slate-500 mt-0.5">Gerencie seus templates de prompt gerados pelo wizard</p>
        </div>
        <a asp-controller="PromptGenerator" asp-action="Index" class="btn btn-primary">
            <i data-lucide="plus" class="w-4 h-4"></i>
            Novo Template
        </a>
    </div>

    <!-- Search -->
    <form method="get" asp-action="Index" class="flex gap-2">
        <div class="relative flex-1 max-w-sm">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
            <input type="text" name="search" value="@search"
                   placeholder="Buscar por nome ou descrição..."
                   class="form-input pl-9 w-full" />
        </div>
        <button type="submit" class="btn btn-secondary">Filtrar</button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a asp-action="Index" class="btn btn-ghost">Limpar</a>
        }
    </form>

    <!-- Table -->
    <div class="card p-0 overflow-hidden">
        @if (!Model.Items.Any())
        {
            <div class="text-center py-16">
                <i data-lucide="file-text" class="w-10 h-10 text-slate-300 mx-auto mb-3"></i>
                <p class="text-sm text-slate-500">Nenhum template encontrado.</p>
                <a asp-controller="PromptGenerator" asp-action="Index" class="btn btn-primary btn-sm mt-3">Criar primeiro template</a>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-200 bg-slate-50">
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Nome</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Descrição</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Versão</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Tecnologias</th>
                        <th class="text-left px-4 py-3 font-medium text-slate-600">Atualizado</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model.Items)
                    {
                        <tr class="hover:bg-slate-50 transition-colors" x-data="{ cloneOpen: false, deleteOpen: false }">
                            <td class="px-4 py-3">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="font-medium text-slate-900 hover:text-brand-600 transition-colors">@item.Name</a>
                            </td>
                            <td class="px-4 py-3 text-slate-500 max-w-xs truncate">@(item.Description ?? "—")</td>
                            <td class="px-4 py-3">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600">
                                    v@(item.CurrentVersionNumber)
                                </span>
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var tech in item.TechnologyNames.Take(3))
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-700">@tech</span>
                                    }
                                    @if (item.TechnologyNames.Count > 3)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-500">+@(item.TechnologyNames.Count - 3)</span>
                                    }
                                </div>
                            </td>
                            <td class="px-4 py-3 text-slate-500">@item.UpdatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-end gap-1">
                                    <!-- Edit -->
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-ghost btn-sm" title="Editar no wizard">
                                        <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                        Editar
                                    </a>

                                    <!-- Clone trigger -->
                                    <button type="button" @@click="cloneOpen = true" class="btn btn-ghost btn-sm" title="Clonar template">
                                        <i data-lucide="copy" class="w-3.5 h-3.5"></i>
                                        Clonar
                                    </button>

                                    <!-- Delete trigger -->
                                    <button type="button" @@click="deleteOpen = true" class="btn btn-ghost btn-sm text-red-600 hover:text-red-700" title="Excluir template">
                                        <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                                        Excluir
                                    </button>
                                </div>

                                <!-- Clone modal -->
                                <div x-show="cloneOpen" x-cloak
                                     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                                     @@keydown.escape.window="cloneOpen = false">
                                    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-sm" @@click.stop>
                                        <h3 class="text-base font-semibold text-slate-900 mb-4">Clonar template</h3>
                                        <form asp-action="Clone" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <label class="block text-sm font-medium text-slate-700 mb-1">Nome do clone</label>
                                            <input type="text" name="newName" value="@(item.Name) (cópia)"
                                                   class="form-input w-full mb-4" required />
                                            <div class="flex justify-end gap-2">
                                                <button type="button" @@click="cloneOpen = false" class="btn btn-ghost">Cancelar</button>
                                                <button type="submit" class="btn btn-primary">Clonar</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                <!-- Delete confirm -->
                                <div x-show="deleteOpen" x-cloak
                                     class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
                                     @@keydown.escape.window="deleteOpen = false">
                                    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-sm" @@click.stop>
                                        <h3 class="text-base font-semibold text-slate-900 mb-2">Excluir template</h3>
                                        <p class="text-sm text-slate-500 mb-4">
                                            Tem certeza que deseja excluir <strong>@item.Name</strong>? Esta ação não pode ser desfeita.
                                        </p>
                                        <div class="flex justify-end gap-2">
                                            <button type="button" @@click="deleteOpen = false" class="btn btn-ghost">Cancelar</button>
                                            <form asp-action="Delete" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-danger">Excluir</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @await Html.PartialAsync("_Pagination", new PagedResult<dynamic>
            {
                TotalCount = Model.TotalCount,
                Page = Model.Page,
                PageSize = Model.PageSize
            })
        }
    </div>
</div>
